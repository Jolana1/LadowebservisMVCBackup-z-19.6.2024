@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #f8f9fa;
    }

    .about-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        margin-top: 30px;
    }

    .about-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border-radius: 12px;
        padding: 60px 25px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        position: relative;
        overflow: hidden;
        margin-bottom: 30px;
    }

        .about-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.10) 0%, transparent 50%),
                        radial-gradient(circle at 80% 80%, rgba(255,255,255,0.10) 0%, transparent 50%);
            pointer-events: none;
        }

        .about-hero > * {
            position: relative;
            z-index: 1;
        }

        .about-hero h1 {
            font-size: 42px;
            font-weight: 800;
            margin: 0 0 12px 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

    .about-subtitle {
        font-size: 18px;
        opacity: 0.95;
        margin: 0 auto 18px auto;
        max-width: 900px;
        line-height: 1.6;
    }

    .about-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .btn-about {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 10px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.25s ease;
        border: none;
    }

    .btn-about-primary {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff !important;
        box-shadow: 0 8px 20px rgba(40,167,69,0.35);
    }

        .btn-about-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(40,167,69,0.45);
        }

    .btn-about-secondary {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff !important;
        box-shadow: 0 8px 20px rgba(23,162,184,0.30);
    }

        .btn-about-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(23,162,184,0.40);
        }

    .btn-about-light {
        background: rgba(255,255,255,0.18);
        color: #fff !important;
        border: 1px solid rgba(255,255,255,0.25);
        backdrop-filter: blur(10px);
    }

        .btn-about-light:hover {
            background: rgba(255,255,255,0.24);
            transform: translateY(-2px);
        }

    .about-section-title {
        color: #5d33fb;
        font-weight: 900;
        font-size: 30px;
        margin: 35px 0 18px 0;
        text-align: center;
    }

    .about-card {
        background: #fff;
        border-radius: 12px;
        padding: 28px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        height: 100%;
        border-top: 4px solid #5d33fb;
    }

    .about-card h3 {
        margin-top: 0;
        color: #2c3e50;
        font-weight: 900;
        font-size: 18px;
    }

    .about-card p {
        color: #666;
        line-height: 1.7;
        margin: 10px 0 0 0;
    }

    .about-list {
        margin: 14px 0 0 0;
        padding-left: 20px;
        color: #333;
        line-height: 1.8;
    }

    .about-highlight {
        background: linear-gradient(135deg, #fff5e6 0%, #ffe0b2 100%);
        border: 2px solid #ff9800;
        border-radius: 12px;
        padding: 22px;
        margin-top: 25px;
        box-shadow: 0 10px 25px rgba(255, 152, 0, 0.18);
    }

    .about-highlight strong {
        color: #d97706;
    }

    .testimonial {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-left: 4px solid #5d33fb;
        border-radius: 12px;
        padding: 18px;
        margin-bottom: 12px;
    }

    .small-note {
        color: #777;
        font-size: 12px;
        line-height: 1.6;
        margin-top: 12px;
    }

    @@media (max-width: 768px) {
        .about-hero {
            padding: 45px 18px;
        }

        .about-hero h1 {
            font-size: 28px;
        }

        .about-subtitle {
            font-size: 15px;
        }
    }
</style>

<div class="about-container">
    <div class="about-hero">
        <h1>ladowebservis.sk</h1>
        <p class="about-subtitle">
            Spájame praktické IT služby a poradenstvo so zameraním na zdravý životný štýl.
            Našim cieľom je prinášať riešenia, ktoré sú jednoduché, funkčné a zrozumiteľné.
        </p>

        <div class="about-actions">
            <a class="btn-about btn-about-primary" href="@Url.Action("Produkty", "Home")"><i class="fa fa-shopping-bag"></i> Produkty</a>
            <a class="btn-about btn-about-secondary" href="@Url.Action("ITservis", "Home")"><i class="fa fa-laptop"></i> IT služby</a>
            <a class="btn-about btn-about-light" href="@Url.Action("Kontakt", "Home")"><i class="fa fa-envelope"></i> Kontakt</a>
        </div>
    </div>

    <h2 class="about-section-title">Čomu sa venujeme</h2>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="about-card">
                <h3>🌿 Zdravie v rovnováhe (Zinzino)</h3>
                <p>
                    Zdravie sa začína rovnováhou. Zameriavame sa na produkty a protokoly, ktoré podporujú
                    vyvážený životný štýl a pomáhajú zorientovať sa v tom, čo telu chýba.
                </p>
                <ul class="about-list">
                    <li>BalanceTest – jednoduchá analýza mastných kyselín v krvi (DBS)</li>
                    <li>Produkty pre omega‑3 rovnováhu, črevá a imunitu</li>
                    <li>Odporúčania a vysvetlenie výsledkov v zrozumiteľnej forme</li>
                </ul>
                <div class="about-highlight">
                    <strong>Tip:</strong> Začnite na stránke <a href="@Url.Action("Zdravie", "Home")">Zdravie</a> alebo si pozrite <a href="@Url.Action("Produkty", "Home")">produkty</a>.
                </div>
                <div class="small-note">
                    *BalanceTest je samotest pomocou suchej kvapky krvi (DBS). Výsledok je dostupný online po spracovaní.
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="about-card" style="border-top-color:#17a2b8;">
                <h3>💻 IT služby pre web a biznis</h3>
                <p>
                    Pomáhame s webom, e‑shopom, úpravami a technickou podporou. Všetko s dôrazom na rýchlosť,
                    bezpečnosť a jednoduchú správu.
                </p>
                <ul class="about-list">
                    <li>Webstránky a e‑shopy (tvorba, úpravy, nasadenie)</li>
                    <li>Údržba, aktualizácie, zálohy, bezpečnostné nastavenia</li>
                    <li>Poradenstvo a riešenie problémov</li>
                </ul>
                <div class="about-highlight" style="border-color:#17a2b8;background: linear-gradient(135deg, #e7f3ff 0%, #eef2ff 100%);">
                    <strong>Máte otázku?</strong> Pozrite <a href="@Url.Action("ITservis", "Home")">IT služby</a> alebo nám <a href="@Url.Action("Kontakt", "Home")">napíšte</a>.
                </div>
            </div>
        </div>
    </div>

    <h2 class="about-section-title">Referencie</h2>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="testimonial">
                <p style="margin:0;"><strong>Juraj</strong> – dlhoročný zákazník</p>
                <p style="margin:8px 0 0 0;">„Produkty Zinzino užívam dlhšie a cítim sa skvele. Môžem ich odporučiť.“</p>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="testimonial">
                <p style="margin:0;"><strong>Janka</strong> – klientka webu</p>
                <p style="margin:8px 0 0 0;">„So službami Ladowebservis mám veľmi dobrú skúsenosť. Odporúčam.“</p>
            </div>
        </div>
    </div>

    <div class="about-hero" style="padding: 40px 25px; margin-top: 10px;">
        <h1 style="font-size: 28px;">Spokojný klient je pre nás najväčšia odmena</h1>
        <p class="about-subtitle" style="margin-bottom: 0;">Neváhajte nám napísať – radi poradíme s produktami aj IT riešeniami.</p>
        <div class="about-actions" style="margin-top: 16px;">
            <a class="btn-about btn-about-light" href="@Url.Action("Kontakt", "Home")"><i class="fa fa-paper-plane"></i> Kontaktovať</a>
            <a class="btn-about btn-about-primary" href="@Url.Action("DownloadEbook", "Home")"><i class="fa fa-book"></i> Bezplatný e‑book</a>
        </div>
    </div>
</div>


















