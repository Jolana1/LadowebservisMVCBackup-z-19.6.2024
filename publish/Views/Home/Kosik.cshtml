@using LadowebservisMVC.Util

@{
    // Track IDs to avoid rendering duplicate entries
    var seenIds = new System.Collections.Generic.HashSet<string>(System.StringComparer.OrdinalIgnoreCase);
}

<style>
    /* ========== MAIN CONTAINER ========== */
    .kosik-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ========== HERO HEADER ========== */
    .kosik-hero {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        padding: 40px 20px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(93, 51, 251, 0.3);
    }

    .kosik-hero h2 {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 20px 0;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        line-height: 1.6;
    }

    /* ========== DISCOUNT NOTICE ========== */
    .discount-notice {
        background: linear-gradient(135deg, #ffeb3b 0%, #ffc107 100%);
        color: #2c3e50;
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
        text-align: center;
    }

    .discount-notice code {
        background: #fff;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 700;
        color: #5d33fb;
        font-size: 16px;
    }

    /* ========== CARD SECTIONS ========== */
    .kosik-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-bottom: 30px;
    }

    .kosik-card h3 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 25px;
        font-size: 22px;
    }

    /* ========== PRODUCT CARDS ========== */
    .product-card {
        position: relative;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #fff;
    }

    .product-card.in-cart {
        border-color: #28a745;
        background: linear-gradient(135deg, #f0fff4 0%, #e8f5e9 100%);
        box-shadow: 0 4px 15px rgba(40, 167, 69, 0.15);
    }

    .product-card:hover {
        border-color: #5d33fb;
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.15);
        transform: translateY(-3px);
    }

    .product-card.in-cart:hover {
        border-color: #28a745;
        box-shadow: 0 8px 20px rgba(40, 167, 69, 0.25);
    }

    .product-qty-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        border: 2px solid #fff;
        z-index: 5;
    }

    .product-in-cart-label {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        z-index: 4;
    }

    .product-card img {
        max-width: 100%;
        max-height: 120px;
        width: auto;
        height: auto;
        object-fit: contain;
        margin: 0 auto;
    }

    .product-card h4 {
        color: #2c3e50;
        font-size: 16px;
        font-weight: 600;
        margin: 15px 0 10px;
    }

    .product-card p {
        color: #28a745;
        font-size: 20px;
        font-weight: 700;
        margin: 10px 0;
    }

    /* ========== BUTTONS ========== */
    .btn-detail {
        background: #17a2b8;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-detail:hover {
        background: #138496;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .btn-add-cart {
        background: #5d33fb;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover {
        background: #4a2fb5;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .product-heart {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 10;
    }

    .product-heart .fa-heart {
        font-size: 20px;
        color: #e25555;
        transition: all 0.3s ease;
    }

    .product-heart:hover .fa-heart {
        transform: scale(1.2);
    }

    /* ========== CART REVIEW ========== */
    .cart-item {
        border: 2px solid #f0f0f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

    .cart-item:hover {
        border-color: #5d33fb;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.1);
    }

    .cart-item-discount {
        background: #e7f3ff;
        border-color: #28a745;
    }

    .cart-item img {
        max-width: 120px;
        max-height: 120px;
        object-fit: contain;
        border-radius: 8px;
    }

    .discount-badge {
        display: inline-block;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 10px;
    }

    .price-original {
        text-decoration: line-through;
        color: #999;
        margin-right: 8px;
    }

    .price-discounted {
        color: #28a745;
        font-weight: 700;
    }

    /* ========== TOTALS ========== */
    .cart-totals {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
    }

    .cart-totals .row {
        margin-bottom: 10px;
        font-size: 16px;
    }

    .cart-totals .row:last-child {
        border-top: 2px solid #5d33fb;
        padding-top: 15px;
        margin-top: 15px;
        font-size: 20px;
        font-weight: 700;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .kosik-hero h2 {
            font-size: 18px;
        }

        .kosik-card {
            padding: 20px;
        }

        .cart-item {
            padding: 15px;
        }

        .cart-item img {
            max-width: 80px;
            max-height: 80px;
        }
    }

    /* ========== ALERT STYLES ========== */
    .alert-info {
        background: #e7f3ff;
        border: 2px solid #5d33fb;
        border-radius: 8px;
        padding: 20px;
    }

    .alert-info h4 {
        color: #5d33fb;
        margin-top: 0;
    }

    /* Fly-to-cart image animation */
    .lws-fly-img {
        position: absolute !important;
        pointer-events: none;
        z-index: 9999;
        border-radius: 6px;
        transition: transform 0.8s ease-in-out, opacity 0.8s ease-in-out;
        opacity: 1;
        will-change: transform, opacity;
    }

    /* ========== FOOTER BUTTONS ========== */
    .footer-action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .footer-btn {
        padding: 14px 32px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .footer-btn-primary {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .footer-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.4);
        color: #fff;
    }

    .footer-btn-secondary {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .footer-btn-secondary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(23, 162, 184, 0.4);
        color: #fff;
    }
</style>

