@section scripts {
    <script>
        function openSideCart() {
            try {
                var cart = document.getElementById('side-cart');
                var overlay = document.getElementById('cart-overlay');
                if (!cart || !overlay) return;
                cart.classList.add('open');
                overlay.classList.add('open');
                cart.setAttribute('aria-hidden', 'false');
                overlay.setAttribute('aria-hidden', 'false');
                cart.focus();
            } catch (e) { }
        }

        (function () {
            var STORAGE_KEY = 'lws_cart_v1';

            function loadCart() {
                try {
                    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function saveCart(cart) {
                try { localStorage.setItem(STORAGE_KEY, JSON.stringify(cart)); } catch (e) { }
            }

            function getProductPrice(key) {
                var catalog = window.__lws_products || {};
                if (catalog && catalog[key] && catalog[key].Price) return parseFloat(catalog[key].Price) || 0;
                if (catalog) {
                    for (var id in catalog) {
                        if (!catalog.hasOwnProperty(id)) continue;
                        var it = catalog[id];
                        if (it && it.Name === key && it.Price) return parseFloat(it.Price) || 0;
                    }
                }
                return ({ 'BalanceTest': 195.00, 'BalanceOil': 55.00, 'Zinobiotic': 40.00, 'ZinzinoXtend': 44.00, 'CollagenBoozt': 85.00 }[key] || 0);
            }

            function getCartTotals(cart) {
                var subtotal = 0, totalQty = 0, discount = 0;
                Object.keys(cart).forEach(function (k) {
                    var item = cart[k];
                    if (!item || (item.quantity || 0) <= 0) return;
                    var q = item.quantity || 0;
                    totalQty += q;
                    var unit = getProductPrice(k);
                    var line = unit * q;
                    subtotal += line;
                    // 10% discount when line amount > 50€ OR product is ZinzinoXtend
                    var isXtend = (String(k) === '3') || (String(k).toLowerCase() === 'zinzinoxtend');
                    if ((line > 50) || isXtend) {
                        discount += line * 0.10;
                    }
                });
                var total = subtotal - discount;
                return { subtotal: subtotal, total: total, discount: discount, totalQty: totalQty };
            }

            function changeQuantity(id, delta) {
                if (!id || !delta) return;
                var cart = loadCart();
                var item = cart[id];
                if (!item) return;
                var current = item.quantity || 0;
                var next = current + delta;
                if (next <= 0) {
                    delete cart[id];
                } else {
                    item.quantity = next;
                    cart[id] = item;
                }
                saveCart(cart);
                renderProducts();
                renderCartReview();
                if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
            }

            function renderProducts() {
                var catalog = window.__lws_products || {};
                var cart = loadCart();
                var container = document.getElementById('productsContainer');
                var productCount = document.getElementById('productCount');

                if (!container) return;

                container.innerHTML = '';
                var allProducts = [];

                // Build product list from catalog
                if (Array.isArray(catalog)) {
                    allProducts = catalog;
                } else {
                    for (var id in catalog) {
                        if (catalog.hasOwnProperty(id)) {
                            allProducts.push(catalog[id]);
                        }
                    }
                }

                // Render each product
                allProducts.forEach(function (p) {
                    if (!p || !p.Id) return;

                    var id = p.Id.toString().trim();
                    var name = p.Name || 'Unknown';
                    var price = parseFloat(p.Price) || 0;
                    var image = p.Image || '/Image/placeholder.png';

                    var qualifiesForDiscount = (price > 50) || (name && name.toLowerCase && name.toLowerCase() === 'zinzinoxtend') || (id === '3');
                    var discountedPrice = qualifiesForDiscount ? price * 0.9 : price;

                    var cartItem = cart[id];
                    var cartQty = cartItem ? (cartItem.quantity || 0) : 0;
                    var isInCart = cartQty > 0;

                    var col = document.createElement('div');
                    col.className = 'col-12 col-sm-6 col-md-4 col-lg-3 mb-4';
                    col.setAttribute('data-product-id', id);
                    col.setAttribute('data-product-name', name.toLowerCase());

                    var cardClass = 'card p-3 text-center product-card' + (isInCart ? ' in-cart' : '');

                    var html = '<div class="' + cardClass + '">';

                    // In cart label
                    if (isInCart) {
                        html += '<span class="product-in-cart-label"><i class="fa fa-check"></i> V košíku</span>';
                    }

                    // Quantity badge
                    if (isInCart) {
                        html += '<div class="product-qty-badge" title="Počet ks v košíku">' + cartQty + '</div>';
                    }

                    // Discount badge
                    if (qualifiesForDiscount) {
                        html += '<span class="discount-badge" style="position: absolute; top: 10px; left: 10px;">-10% ZĽAVA</span>';
                    }

                    // Heart button
                    html += '<button type="button" class="product-heart" data-id="' + id + '" title="Pridať do obľúbených" aria-label="Pridať do obľúbených">';
                    html += '<i class="fa fa-heart" aria-hidden="true"></i>';
                    html += '</button>';

                    // Image
                    html += '<img src="' + image + '" alt="' + name + '" class="img-fluid mx-auto mb-3" />';

                    // Name
                    html += '<h4>' + name + '</h4>';

                    // Price
                    if (qualifiesForDiscount) {
                        html += '<p>';
                        html += '<span class="price-original">€' + price.toFixed(2) + '</span>';
                        html += '<span class="price-discounted">€' + discountedPrice.toFixed(2) + '</span>';
                        html += '</p>';
                    } else {
                        html += '<p>€' + price.toFixed(2) + '</p>';
                    }

                    // Buttons
                    html += '<div class="mt-auto d-flex gap-2 justify-content-center align-items-center flex-wrap">';

                    if (isInCart) {
                        html += '<div class="btn-group btn-group-sm" role="group">';
                        html += '<button type="button" class="btn btn-outline-success qty-dec-product" data-id="' + id + '" title="Znížiť množstvo">−</button>';
                        html += '<button type="button" class="btn btn-light" disabled>' + cartQty + '</button>';
                        html += '<button type="button" class="btn btn-outline-success qty-inc-product" data-id="' + id + '" title="Zvýšiť množstvo">+</button>';
                        html += '</div>';
                    } else {
                        html += '<button type="button" class="btn btn-sm btn-add-cart add-to-cart" data-id="' + id + '">';
                        html += '<i class="fa fa-cart-plus"></i> Do košíka';
                        html += '</button>';
                    }

                    html += '<a class="btn btn-sm btn-detail" href="/Home/Produkty?q=' + encodeURIComponent(name) + '" title="Zobraziť detail produktu">';
                    html += '<i class="fa fa-info-circle"></i> Detail';
                    html += '</a>';
                    html += '</div>';

                    html += '</div>';
                    col.innerHTML = html;
                    container.appendChild(col);
                });

                // Update product count
                if (productCount) {
                    productCount.textContent = '(' + allProducts.length + ' produktov)';
                }

                // Attach event listeners
                container.querySelectorAll('.add-to-cart').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var id = this.getAttribute('data-id');
                        var cart = loadCart();
                        var item = cart[id];
                        if (!item) {
                            var prodInfo = allProducts.find(function (p) { return p.Id.toString() === id; });
                            cart[id] = { quantity: 1, image: prodInfo ? prodInfo.Image : '' };
                        } else {
                            item.quantity = (item.quantity || 0) + 1;
                        }
                        saveCart(cart);
                        renderProducts();
                        renderCartReview();
                        if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                    });
                });

                container.querySelectorAll('.qty-inc-product').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), 1);
                    });
                });

                container.querySelectorAll('.qty-dec-product').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), -1);
                    });
                });

                container.querySelectorAll('.product-heart').forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var id = this.getAttribute('data-id');
                        var prodInfo = allProducts.find(function (p) { return p.Id.toString() === id; });
                        if (prodInfo) {
                            var favs = JSON.parse(localStorage.getItem('lws_favorites') || '{}');
                            if (favs[id]) {
                                delete favs[id];
                            } else {
                                favs[id] = { name: prodInfo.Name, price: prodInfo.Price, image: prodInfo.Image };
                            }
                            localStorage.setItem('lws_favorites', JSON.stringify(favs));
                            this.classList.toggle('active');
                        }
                    });
                });
            }

            function renderCartReview() {
                var cart = loadCart();
                var container = document.getElementById('cartReviewList');
                if (!container) return;

                container.innerHTML = '';
                var hasItems = false;
                var catalog = window.__lws_products || {};

                Object.keys(cart).forEach(function (k) {
                    var item = cart[k];
                    if (!item || (item.quantity || 0) <= 0) return;
                    hasItems = true;

                    var productInfo = catalog && catalog[k] ? catalog[k] : null;
                    var displayName = productInfo && productInfo.Name ? productInfo.Name : k;
                    var imgSrc = item.image || (productInfo && productInfo.Image) || ('/Image/' + k + '.png');
                    var unitPrice = getProductPrice(k);
                    var qtyVal = item.quantity || 0;
                    var baseLine = unitPrice * qtyVal;
                    var qualifiesForDiscount = (baseLine > 50) || (String(k) === '3') || (displayName && displayName.toLowerCase && displayName.toLowerCase() === 'zinzinoxtend');
                    var discountAmount = qualifiesForDiscount ? baseLine * 0.10 : 0;
                    var lineTotal = baseLine - discountAmount;

                    var itemDiv = document.createElement('div');
                    itemDiv.className = 'cart-item' + (qualifiesForDiscount ? ' cart-item-discount' : '');

                    var html = '<div class="row align-items-center">';
                    html += '<div class="col-md-2 col-4 text-center mb-3 mb-md-0">';
                    html += '<img src="' + imgSrc + '" alt="' + displayName + '" class="img-fluid">';
                    html += '</div>';
                    html += '<div class="col-md-5 col-8 mb-3 mb-md-0">';
                    html += '<h5 style="color:#5d33fb; margin-bottom:10px;">' + displayName + '</h5>';
                    html += '<p class="mb-1"><small>ID: ' + k + '</small></p>';

                    if (qualifiesForDiscount) {
                        html += '<p class="mb-1">';
                        html += 'Cena za ks: <span class="price-original">€' + unitPrice.toFixed(2) + '</span> ';
                        html += '<span class="price-discounted">€' + (unitPrice * 0.9).toFixed(2) + '</span>';
                        html += '<span class="discount-badge">-10%</span>';
                        html += '</p>';
                        html += '<p class="mb-1">Množstvo: <strong>' + qtyVal + '</strong></p>';
                        html += '<p class="mb-0">Suma: <strong style="color:#28a745; font-size:18px;">€' + lineTotal.toFixed(2) + '</strong> ';
                        html += '<small style="color:#999;">(ušetrili ste €' + discountAmount.toFixed(2) + ')</small></p>';
                    } else {
                        html += '<p class="mb-1">Cena za ks: <strong>€' + unitPrice.toFixed(2) + '</strong></p>';
                        html += '<p class="mb-1">Množstvo: <strong>' + qtyVal + '</strong></p>';
                        html += '<p class="mb-0">Suma: <strong style="font-size:18px;">€' + lineTotal.toFixed(2) + '</strong></p>';
                    }

                    html += '</div>';
                    html += '<div class="col-md-5 col-12 text-md-end">';
                    html += '<div class="btn-group mb-2" role="group">';
                    html += '<button type="button" class="btn btn-sm btn-outline-secondary qty-dec" data-id="' + k + '" title="Znížiť množstvo">−</button>';
                    html += '<span class="btn btn-sm btn-light disabled">' + qtyVal + '</span>';
                    html += '<button type="button" class="btn btn-sm btn-outline-secondary qty-inc" data-id="' + k + '" title="Zvýšiť množstvo">+</button>';
                    html += '</div><br>';
                    html += '<a href="/Home/Produkty?q=' + encodeURIComponent(displayName) + '" class="btn btn-sm btn-detail me-2 mb-2"><i class="fa fa-info-circle"></i> Detail</a>';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-item mb-2" data-id="' + k + '"><i class="fa fa-trash"></i> Odstrániť</button>';
                    html += '</div>';
                    html += '</div>';

                    itemDiv.innerHTML = html;
                    container.appendChild(itemDiv);
                });

                // Attach event listeners
                container.querySelectorAll('.qty-dec').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), -1);
                    });
                });

                container.querySelectorAll('.qty-inc').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), 1);
                    });
                });

                container.querySelectorAll('.remove-item').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var id = this.getAttribute('data-id');
                        var cartNow = loadCart();
                        if (cartNow && cartNow[id]) {
                            delete cartNow[id];
                            saveCart(cartNow);
                        }
                        renderProducts();
                        renderCartReview();
                        if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                    });
                });

                // Update totals
                var totals = getCartTotals(cart);
                var totalsSection = document.getElementById('cartTotalsSection');
                var subtotalEl = document.getElementById('cartSubtotal');
                var discountEl = document.getElementById('cartDiscount');
                var totalEl = document.getElementById('cartTotal');
                var discountRow = document.getElementById('discountRow');

                if (!totalsSection || !subtotalEl || !totalEl || !discountRow || !discountEl) {
                    // Missing totals elements in DOM; avoid crashing the whole page.
                    return;
                }

                if (hasItems) {
                    totalsSection.style.display = 'block';
                    subtotalEl.textContent = '€' + totals.subtotal.toFixed(2);
                    totalEl.textContent = '€' + totals.total.toFixed(2);

                    if (totals.discount > 0) {
                        discountRow.style.display = 'flex';
                        discountEl.textContent = '-€' + totals.discount.toFixed(2);
                    } else {
                        discountRow.style.display = 'none';
                    }
                } else {
                    totalsSection.style.display = 'none';
                    container.innerHTML = '<div class="alert alert-warning text-center"><i class="fa fa-shopping-cart"></i> Váš košík je prázdny</div>';
                }

                // Update header cart badge
                if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
            }

            // Clear cart button
            document.getElementById('clear-cart-btn').addEventListener('click', function () {
                if (confirm('Naozaj chcete vyprázdniť celý košík?')) {
                    localStorage.removeItem(STORAGE_KEY);
                    renderProducts();
                    renderCartReview();
                    if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                }
            });

            // Initial render
            renderProducts();
            renderCartReview();

            // Search functionality - match products by name and ID
            var searchInput = document.getElementById('productSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var searchTerm = this.value.toLowerCase().trim();
                    var productCards = document.querySelectorAll('#productsContainer [data-product-id]');
                    var visibleCount = 0;

                    productCards.forEach(function (card) {
                        var productName = card.getAttribute('data-product-name') || '';
                        var productId = card.getAttribute('data-product-id') || '';
                        var searchableText = (productName + ' ' + productId).toLowerCase();

                        // Show/hide based on search match
                        var matches = !searchTerm || searchableText.indexOf(searchTerm) >= 0;
                        card.style.display = matches ? '' : 'none';

                        if (matches) {
                            visibleCount++;
                        }
                    });

                    // Update product count display
                    var allCount = productCards.length;
                    var productCountEl = document.getElementById('productCount');
                    if (productCountEl) {
                        if (searchTerm) {
                            productCountEl.textContent = '(' + visibleCount + ' z ' + allCount + ' produktov)';
                        } else {
                            productCountEl.textContent = '(' + allCount + ' produktov)';
                        }
                    }
                });
            }
        })();
    </script>
}























































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































