<script>
    // Stock counter animation - simulates real-time stock depletion
    (function() {
        var initialStock = 50;
        var currentStock = 48;
        var stockCounter = document.getElementById('stockCounter');

        // Simulate stock depletion every few minutes
        function updateStock() {
            if (currentStock > 5) {
                currentStock = Math.max(5, currentStock - Math.floor(Math.random() * 3));
                if (stockCounter) {
                    stockCounter.textContent = currentStock + ' balíkov';

                    // Add urgency if stock is low
                    if (currentStock <= 10) {
                        stockCounter.style.color = '#ff6b6b';
                        stockCounter.style.fontWeight = '700';
                    }
                }
            }
        }

        // Update stock every 5-10 minutes
        setInterval(updateStock, Math.random() * 300000 + 300000);

        // Animate hero buttons on page load
        window.addEventListener('load', function() {
            var buttons = document.querySelectorAll('.cta-primary, .cta-secondary');
            buttons.forEach(function(btn, index) {
                setTimeout(function() {
                    btn.style.animation = 'slideDown 0.5s ease';
                }, index * 200);
            });
        });

        // Smooth scroll to offer section
        var offerLink = document.querySelector('a[href="#special-offer"]');
        if (offerLink) {
            offerLink.addEventListener('click', function(e) {
                e.preventDefault();
                var target = document.getElementById('special-offer');
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        }
    })();
</script>





















































































