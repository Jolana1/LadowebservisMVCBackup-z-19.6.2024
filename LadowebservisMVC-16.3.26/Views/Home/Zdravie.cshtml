@{
    ViewBag.Title = "Zdravie v rovnováhe - Začnite Novým rokom 2026";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Sales Page Styles */
    body {
        background: #f8f9fa;
    }

    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 60px 20px;
        text-align: center;
        border-radius: 12px;
        margin-bottom: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    }

        .hero-section h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .hero-section .lead {
            font-size: 20px;
            margin-bottom: 30px;
            line-height: 1.6;
        }

    .cta-primary {
        background: #28a745;
        color: #fff !important;
        padding: 18px 40px;
        font-size: 18px;
        font-weight: 700;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
        box-shadow: 0 8px 20px rgba(40,167,69,0.3);
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

        .cta-primary:hover {
            background: #218838;
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(40,167,69,0.4);
            color: #fff !important;
        }

    .section-title {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 30px;
        font-size: 36px;
        text-align: center;
    }

    .benefit-card {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        margin-bottom: 30px;
        transition: transform 0.3s ease;
        border-top: 4px solid #5d33fb;
    }

        .benefit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }

    .benefit-icon {
        font-size: 48px;
        color: #5d33fb;
        margin-bottom: 15px;
    }

    .problem-card {
        background: #fff;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        margin-bottom: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

        .problem-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

    .problem-icon {
        font-size: 42px;
        margin-bottom: 10px;
    }

    .testimonial-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 25px;
        border-radius: 10px;
        border-left: 4px solid #5d33fb;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }

        .testimonial-card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

    .price-badge {
        background: #ffcc00;
        color: #2c3e50;
        padding: 8px 20px;
        border-radius: 20px;
        font-size: 18px;
        font-weight: 700;
        display: inline-block;
        margin: 10px 0;
    }

    .urgency-banner {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
        color: #fff;
        padding: 20px;
        text-align: center;
        border-radius: 8px;
        margin: 30px 0;
        font-weight: 600;
        font-size: 18px;
        box-shadow: 0 8px 20px rgba(255, 107, 107, 0.3);
    }

    .special-offer-box {
        background: linear-gradient(135deg, #fff5e6 0%, #ffe0b2 100%);
        border: 3px solid #ff9800;
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(255, 152, 0, 0.2);
        margin-bottom: 40px;
    }

    .product-feature-list {
        font-size: 18px;
        color: #2c3e50;
        line-height: 2;
    }

        .product-feature-list li {
            margin-bottom: 12px;
        }

    .stats-row {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        margin: 40px 0;
        gap: 20px;
    }

    .stat-item {
        text-align: center;
        flex: 1;
        min-width: 200px;
        padding: 30px;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    .stat-number {
        font-size: 48px;
        font-weight: 700;
        color: #5d33fb;
        margin-bottom: 10px;
    }

    .stat-label {
        font-size: 16px;
        color: #666;
    }

    .process-steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 25px;
        margin: 40px 0;
    }

    .step-item {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        border-top: 4px solid #5d33fb;
        transition: all 0.3s ease;
    }

        .step-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }

    .step-item strong {
        color: #5d33fb;
        font-size: 18px;
        display: block;
        margin-bottom: 10px;
    }

    .guarantee-box {
        background: linear-gradient(135deg, #e7f3ff 0%, #f0e6ff 100%);
        border: 3px solid #5d33fb;
        border-radius: 10px;
        padding: 40px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .faq-item {
        background: #fff;
        padding: 25px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        border-left: 4px solid #5d33fb;
    }

    .faq-item h4 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .faq-item p {
        color: #666;
        margin: 0;
    }

    .trust-badges {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        text-align: center;
        color: #999;
        font-size: 14px;
    }

    .container {
        max-width: 1200px;
    }

    @@media (max-width: 768px) {
        .hero-section h1 {
            font-size: 28px;
        }

        .hero-section .lead {
            font-size: 16px;
        }

        .section-title {
            font-size: 26px;
        }

        .cta-primary {
            padding: 14px 30px;
            font-size: 16px;
            width: 100%;
        }

        .special-offer-box {
            padding: 25px;
        }

        .benefit-card {
            padding: 20px;
        }

        .benefit-icon {
            font-size: 36px;
        }

        .stats-row {
            flex-direction: column;
        }

        .stat-item {
            min-width: 100%;
        }

        .urgency-banner {
            font-size: 14px;
            padding: 15px;
        }

        .process-steps {
            grid-template-columns: 1fr;
        }

        .guarantee-box {
            padding: 25px;
        }
    }

    @@media (max-width: 576px) {
        .hero-section {
            padding: 40px 15px;
        }

        .hero-section h1 {
            font-size: 24px;
        }

        .section-title {
            font-size: 22px;
        }

        h3 {
            font-size: 18px;
        }

        .special-offer-box {
            padding: 20px;
            border-width: 2px;
        }

        .product-feature-list {
            font-size: 16px;
        }

        .cta-primary {
            font-size: 14px;
            padding: 12px 20px;
        }

        .benefit-card {
            padding: 15px;
        }

        .stat-number {
            font-size: 36px;
        }
    }
</style>

