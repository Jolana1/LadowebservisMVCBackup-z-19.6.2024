            .site-footer {
                padding: 25px 15px 12px;
                margin-top: 40px;
            }

            .site-footer-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .site-footer-section h4 {
                font-size: 13px;
                margin-bottom: 10px;
            }

            .social-links {
                justify-content: center;
            }

            .payment-methods {
                justify-content: center;
            }

            .site-footer-links {
                flex-direction: column;
                gap: 8px;
            }
        }

        @@media (max-width: 480px) {
            .site-footer {
                padding: 20px 12px 10px;
            }

            .site-footer-section h4 {
                font-size: 12px;
            }

            .site-footer a,
            .contact-info-item {
                font-size: 12px;
            }

            .payment-icon {
                padding: 5px 8px;
            }

                .payment-icon img {
                    height: 20px;
                }

            .social-links a {
                width: 32px;
                height: 32px;
                font-size: 14px;
            }

            .footer-copyright {
                font-size: 11px;
            }
        }

        /* ===== SECTION TRANSITION ANIMATIONS ===== */
        .fade-in {
            animation: fadeInSection 0.4s ease-in-out;
        }

        .fade-out {
            animation: fadeOutSection 0.3s ease-in-out forwards;
        }

        @@keyframes fadeInSection {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeOutSection {
            from {
                opacity: 1;
                transform: translateY(0);
            }

            to {
                opacity: 0;
                transform: translateY(10px);
            }
        }

        /* Smooth transition for side cart chat when exit intent appears */
        .side-cart-chat {
            transition: all 0.3s ease-in-out;
            opacity: 1;
            visibility: visible;
        }

            .side-cart-chat.hidden-by-exit-intent {
                opacity: 0.5;
                pointer-events: none;
                filter: blur(2px);
            }

        /* Exit Intent Popup Styles */
        .exit-intent-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            animation: fadeIn 0.3s ease;
        }

            .exit-intent-overlay.show {
                display: flex;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .exit-intent-modal {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 50px rgba(0, 0, 0, 0.3);
            max-width: 450px;
            width: 90%;
            padding: 40px 30px;
            position: relative;
            animation: slideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .exit-intent-close {
            position: absolute;
            top: 12px;
            right: 12px;
            background: none;
            border: none;
            font-size: 24px;
            color: #999;
            cursor: pointer;
            padding: 6px;
            transition: all 0.2s ease;
        }

            .exit-intent-close:hover {
                color: #5d33fb;
                transform: scale(1.1);
            }

        .exit-intent-content h2 {
            margin: 0 0 8px 0;
            font-size: 28px;
            color: #5d33fb;
            font-weight: 700;
            text-align: center;
        }

        .exit-intent-subtitle {
            margin: 0 0 25px 0;
            font-size: 14px;
            color: #666;
            text-align: center;
        }

        /* Offer Section */
        .exit-intent-offer {
            background: linear-gradient(135deg, #f5f7fa 0%, #e7f3ff 100%);
            border: 2px solid #5d33fb;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: center;
        }

        .offer-badge {
            display: inline-block;
            background: #5d33fb;
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 10px;
            letter-spacing: 0.5px;
        }

        .offer-text {
            margin: 8px 0;
            font-size: 18px;
            color: #333;
            font-weight: 600;
        }

        .offer-code {
            margin: 0;
            font-size: 13px;
            color: #666;
        }

            .offer-code code {
                background: #fff;
                padding: 4px 8px;
                border-radius: 4px;
                font-family: 'Courier New', monospace;
                font-weight: 700;
                color: #5d33fb;
                border: 1px solid #e0e0e0;
            }

        /* Action Buttons */
        .exit-intent-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 15px;
        }

        .btn-ebook,
        .btn-register {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
        }

        .btn-ebook {
            background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
            color: #fff;
            box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
        }

            .btn-ebook:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 16px rgba(93, 51, 251, 0.4);
                color: #fff;
            }

        .btn-register {
            background: #f0f0f0;
            color: #5d33fb;
            border: 2px solid #5d33fb;
        }

            .btn-register:hover {
                background: #5d33fb;
                color: #fff;
                transform: translateY(-2px);
            }

        /* Info Section */
        .exit-intent-info {
            background: #f9f9f9;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
            font-size: 12px;
        }

            .exit-intent-info p {
                margin: 6px 0;
                color: #666;
                display: flex;
                align-items: center;
            }

            .exit-intent-info i {
                color: #5d33fb;
                margin-right: 8px;
                font-size: 14px;
            }

        /* Dismiss Button */
        .btn-dismiss {
            width: 100%;
            padding: 10px;
            background: none;
            border: 1px solid #ddd;
            color: #666;
            font-size: 13px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: 500;
        }

            .btn-dismiss:hover {
                border-color: #999;
                color: #333;
                background: #fafafa;
            }

        /* Responsive */
        @@media (max-width: 600px) {
            .exit-intent-modal {
                padding: 30px 20px;
                max-width: 95%;
            }

            .exit-intent-content h2 {
                font-size: 24px;
            }

            .exit-intent-actions {
                grid-template-columns: 1fr;
            }

            .btn-ebook,
            .btn-register {
                padding: 10px 12px;
                font-size: 12px;
            }
        }
    </style>

