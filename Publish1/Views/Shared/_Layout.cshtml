    <script>
        (function () {
            function loadShipping() {
                try { return JSON.parse(localStorage.getItem('lws_shipping_v1') || '{}') || {}; } catch (e) { return {}; }
            }

            function saveShipping(ship) {
                try { localStorage.setItem('lws_shipping_v1', JSON.stringify(ship || {})); } catch (e) { }
            }

            function isPickupMethod(method) {
                return method === 'zasielkovna' || method === 'packeta' || method === 'dpd-pickup';
            }

            function isCourierMethod(method) {
                return method === 'courier' || method === 'dpd-courier';
            }

            function shippingLabel(method) {
                if (method === 'zasielkovna' || method === 'packeta') return 'Zásielkovňa / Packeta';
                if (method === 'dpd-pickup') return 'DPD odberné miesto';
                if (method === 'dpd-courier') return 'DPD kuriér na adresu';
                if (method === 'courier') return 'Kuriér na adresu';
                return '';
            }

            function renderSideCartShippingSummary() {
                var ship = loadShipping();
                var method = (ship.method || '').toString();

                var methodSelect = document.getElementById('sidecart-shipping-method');
                var shippingHelp = document.getElementById('sidecart-shipping-help');
                var pickupPanel = document.getElementById('sidecart-pickup-panel');
                var pickupLabel = document.getElementById('sidecart-pickup-label');
                var pickupHelp = document.getElementById('sidecart-pickup-help');
                var pickupButton = document.getElementById('sidecart-pickup-btn');
                var pickupCode = document.getElementById('sidecart-pickup-code');
                var pickupName = document.getElementById('sidecart-pickup-name');
                var courierPanel = document.getElementById('sidecart-courier-panel');
                var address1 = document.getElementById('sidecart-address-line1');
                var address2 = document.getElementById('sidecart-address-line2');
                var city = document.getElementById('sidecart-address-city');
                var zip = document.getElementById('sidecart-address-zip');
                var country = document.getElementById('sidecart-address-country');
                var pickupSummary = document.getElementById('shipping-pickup-summary');

                if (methodSelect && methodSelect.value !== method) methodSelect.value = method;
                if (pickupPanel) pickupPanel.style.display = isPickupMethod(method) ? 'block' : 'none';
                if (courierPanel) courierPanel.style.display = isCourierMethod(method) ? 'block' : 'none';

                if (pickupLabel) pickupLabel.textContent = method === 'dpd-pickup' ? 'DPD odberné miesto' : 'Výdajné miesto';
                if (pickupHelp) {
                    pickupHelp.textContent = method === 'dpd-pickup'
                        ? 'DPD funguje iba ako ručné zadanie odberného miesta. Zadajte kód a názov alebo adresu DPD odberného miesta.'
                        : 'Pre Zásielkovňu môžete použiť widget alebo doplniť kód a názov miesta ručne.';
                }
                if (pickupButton) pickupButton.style.display = (method === 'zasielkovna' || method === 'packeta') ? 'block' : 'none';

                if (pickupCode && pickupCode.value !== (ship.pickupPoint || '')) pickupCode.value = ship.pickupPoint || '';
                if (pickupName && pickupName.value !== (ship.pickupPointName || '')) pickupName.value = ship.pickupPointName || '';
                if (address1 && address1.value !== (ship.addressLine1 || '')) address1.value = ship.addressLine1 || '';
                if (address2 && address2.value !== (ship.addressLine2 || '')) address2.value = ship.addressLine2 || '';
                if (city && city.value !== (ship.city || '')) city.value = ship.city || '';
                if (zip && zip.value !== (ship.zip || '')) zip.value = ship.zip || '';
                if (country && country.value !== (ship.country || '')) country.value = ship.country || '';

                if (shippingHelp) {
                    shippingHelp.textContent = method
                        ? ('Zvolená doprava: ' + shippingLabel(method))
                        : 'Cena dopravy sa prepočíta podľa košíka.';
                }

                if (pickupSummary) {
                    if (isPickupMethod(method)) {
                        var code = ship.pickupPoint || '';
                        var name = ship.pickupPointName || '';
                        pickupSummary.innerHTML = code || name
                            ? ('<strong>' + shippingLabel(method) + ':</strong> ' + (name || '-') + (code ? (' (' + code + ')') : ''))
                            : ('<strong>' + shippingLabel(method) + ':</strong> Nevybrané odberné miesto');
                    } else if (isCourierMethod(method)) {
                        var line = [ship.addressLine1, ship.addressLine2].filter(Boolean).join(', ');
                        var place = [ship.zip, ship.city].filter(Boolean).join(' ');
                        var full = [line, place, ship.country].filter(Boolean).join(', ');
                        pickupSummary.innerHTML = '<strong>' + shippingLabel(method) + ':</strong> ' + (full || 'Nevyplnená doručovacia adresa');
                    } else {
                        pickupSummary.textContent = '';
                    }
                }
            }

            function notifyShippingChange() {
                try {
                    if (typeof window.lwsRefreshCheckoutShipping === 'function') window.lwsRefreshCheckoutShipping();
                } catch (e) { }
                try {
                    if (typeof window.lwsRenderCartHeader === 'function') window.lwsRenderCartHeader();
                } catch (e) { }
            }

            window.lwsSetShippingMethod = function (method) {
                var ship = loadShipping();
                ship.method = method || '';

                if (!isPickupMethod(ship.method)) {
                    ship.pickupPoint = '';
                    ship.pickupPointName = '';
                    ship.pickupPointJson = '';
                }
                if (!isCourierMethod(ship.method)) {
                    ship.addressLine1 = '';
                    ship.addressLine2 = '';
                    ship.city = '';
                    ship.zip = '';
                    ship.country = '';
                }

                saveShipping(ship);
                renderSideCartShippingSummary();
                notifyShippingChange();
            };

            window.lwsOpenPacketaWidget = function () {
                var apiKey = (window.__packetaApiKey || '').toString();
                if (!apiKey || !window.Packeta || !window.Packeta.Widget || typeof window.Packeta.Widget.pick !== 'function') return;

                window.Packeta.Widget.pick(apiKey, function (point) {
                    if (!point) return;
                    var ship = loadShipping();
                    ship.method = 'zasielkovna';
                    ship.pickupPoint = point.id || point.code || point.place || '';
                    ship.pickupPointName = point.name || point.place || point.city || '';
                    ship.pickupPointJson = JSON.stringify(point);
                    saveShipping(ship);
                    renderSideCartShippingSummary();
                    notifyShippingChange();
                });
            };

            window.lwsRefreshShippingSummary = renderSideCartShippingSummary;

            document.addEventListener('DOMContentLoaded', function () {
                var pickupBtn = document.getElementById('sidecart-pickup-btn');
                var pickupCode = document.getElementById('sidecart-pickup-code');
                var pickupName = document.getElementById('sidecart-pickup-name');
                var address1 = document.getElementById('sidecart-address-line1');
                var address2 = document.getElementById('sidecart-address-line2');
                var city = document.getElementById('sidecart-address-city');
                var zip = document.getElementById('sidecart-address-zip');
                var country = document.getElementById('sidecart-address-country');
                var methodSelect = document.getElementById('sidecart-shipping-method');

                function syncPickupInputs() {
                    var ship = loadShipping();
                    if (!ship.method) ship.method = 'zasielkovna';
                    ship.pickupPoint = pickupCode ? (pickupCode.value || '').trim() : '';
                    ship.pickupPointName = pickupName ? (pickupName.value || '').trim() : '';
                    saveShipping(ship);
                    renderSideCartShippingSummary();
                    notifyShippingChange();
                }

                function syncCourierInputs() {
                    var ship = loadShipping();
                    if (!ship.method) ship.method = 'courier';
                    ship.addressLine1 = address1 ? (address1.value || '').trim() : '';
                    ship.addressLine2 = address2 ? (address2.value || '').trim() : '';
                    ship.city = city ? (city.value || '').trim() : '';
                    ship.zip = zip ? (zip.value || '').trim() : '';
                    ship.country = country ? (country.value || '').trim() : '';
                    saveShipping(ship);
                    renderSideCartShippingSummary();
                    notifyShippingChange();
                }

                if (pickupBtn) pickupBtn.addEventListener('click', window.lwsOpenPacketaWidget);
                if (pickupCode) pickupCode.addEventListener('input', syncPickupInputs);
                if (pickupName) pickupName.addEventListener('input', syncPickupInputs);
                if (address1) address1.addEventListener('input', syncCourierInputs);
                if (address2) address2.addEventListener('input', syncCourierInputs);
                if (city) city.addEventListener('input', syncCourierInputs);
                if (zip) zip.addEventListener('input', syncCourierInputs);
                if (country) country.addEventListener('input', syncCourierInputs);

                if (methodSelect) {
                    var ship = loadShipping();
                    if (!ship.method && methodSelect.value) {
                        ship.method = methodSelect.value;
                        saveShipping(ship);
                    }
                }

                renderSideCartShippingSummary();
            });
        })();
    </script>

    <script>
        function toggleMiniProducts() {
            var ul = document.getElementById('mini-products-list');
            if (!ul) return;
            if (ul.childElementCount === 0) {
                try {
                    var map = window.__lws_products || {};
                    var arr = [];
                    for (var k in map) { if (Object.prototype.hasOwnProperty.call(map, k)) arr.push(map[k]); }
                    arr.sort(function (a, b) { var an = (a && a.Name) || ''; var bn = (b && b.Name) || ''; return an.localeCompare(bn); });
                    var max = 8;
                    for (var i = 0; i < arr.length && i < max; i++) {
                        var p = arr[i]; if (!p) continue;
                        var li = document.createElement('li');
                        li.className = 'mini-item';
                        var name = (p.Name || p.Id || '').toString();
                        var id = (p.Id || '').toString();
                        var imgSrc = (p.Image || '').toString();
                        var imgTag = imgSrc ? '<img src="' + imgSrc + '" alt="' + name.replace(/"/g, '&quot;') + '">' : '';
                        // removed add button from side cart mini list
                        li.innerHTML = imgTag + '<span class="mini-name"><a href="/Home/Produkty?id=' + encodeURIComponent(id) + '" title="' + name.replace(/"/g, '&quot;') + '">' + name + '</a></span>';
                        ul.appendChild(li);
                    }
                } catch (e) { /* ignore */ }
            }
            ul.style.display = (ul.style.display === 'none' || !ul.style.display) ? 'block' : 'none';
        }
    </script>

