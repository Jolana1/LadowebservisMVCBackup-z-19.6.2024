    <script>
        function toggleTopnav() {
            var x = document.getElementById("myTopnav");
            if (!x) return;
            if (x.className === "collapse") { x.className += " responsive"; } else { x.className = "collapse"; }
        }

        function toggleCart() {
            var cart = document.getElementById('side-cart');
            var overlay = document.getElementById('cart-overlay');
            if (!cart || !overlay) return;
            var open = cart.classList.toggle('open');
            overlay.classList.toggle('open', open);
            cart.setAttribute('aria-hidden', !open);
            overlay.setAttribute('aria-hidden', !open);
            if (open) { cart.focus(); }
        }

        function closeCart() {
            var cart = document.getElementById('side-cart');
            var overlay = document.getElementById('cart-overlay');
            if (!cart || !overlay) return;
            cart.classList.remove('open');
            overlay.classList.remove('open');
            cart.setAttribute('aria-hidden', 'true');
            overlay.setAttribute('aria-hidden', 'true');
            document.getElementById('cartToggle').focus();
        }

        function toggleNavSearch() {
            var wrap = document.getElementById('navQuickSearch');
            var input = document.getElementById('navQuickSearchInput');
            if (!wrap || !input) return;

            var isHidden = (wrap.style.display === 'none' || wrap.style.display === '');
            wrap.style.display = isHidden ? 'inline-block' : 'none';
            wrap.classList.toggle('is-open', isHidden);

            if (isHidden) {
                input.focus();
                input.classList.remove('pulse-placeholder');
                void input.offsetWidth; // restart animation
                input.classList.add('pulse-placeholder');
            } else {
                wrap.classList.remove('is-open');
            }
        }

        function submitNavQuickSearch() {
            try {
                var input = document.getElementById('navQuickSearchInput');
                var q = (input && input.value) ? input.value : '';
                q = q.trim();
                if (!q) {
                    if (input) {
                        input.focus();
                        input.classList.remove('pulse-placeholder');
                        void input.offsetWidth; // restart animation
                        input.classList.add('pulse-placeholder');
                    }
                    return false;
                }

                window.location.href = '/Home/Produkty?q=' + encodeURIComponent(q);
            } catch (e) { }
            return false;
        }
    </script>

