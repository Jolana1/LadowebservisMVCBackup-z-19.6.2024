@using System.Diagnostics
@using LadowebservisMVC.Models
@{
    ViewBag.Title = "Objednavky";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Diagnostics init
    var _viewTimer = Stopwatch.StartNew();
    var _memBefore = GC.GetTotalMemory(false);

    // Access gating flags
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var canOrder = (TempData["CanOrder"] as bool?) == true || (ViewBag.CanOrder as bool?) == true;

    // Registered user info
    var memberInfo = Session != null ? (Session["MemberInfo"] as MemberInfoModel) : null;
}

<style>
    /* ===== PAGE BACKGROUND ===== */
    .orders-page {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        padding: 20px 0;
    }

    /* ===== HERO SECTION ===== */
    .orders-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 40px 20px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }

    .orders-hero h1 {
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 15px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    }

    .orders-hero p {
        font-size: 16px;
        opacity: 0.95;
        margin-bottom: 0;
        line-height: 1.6;
    }

    /* ===== CARD SECTIONS ===== */
    .orders-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-bottom: 30px;
        transition: all 0.3s ease;
    }

    .orders-card:hover {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }

    .orders-card h2 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 25px;
        font-size: 28px;
        padding-bottom: 15px;
        border-bottom: 3px solid #5d33fb;
    }

    /* ===== STATS GRID ===== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-box {
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .stat-value {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .stat-label {
        font-weight: 600;
        margin-bottom: 5px;
        font-size: 14px;
    }

    .stat-description {
        font-size: 12px;
        opacity: 0.8;
    }

    /* ===== POINTS SECTION ===== */
    .points-section {
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        border-radius: 10px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(255, 215, 0, 0.2);
    }

    .points-header {
        color: #ff9800;
        font-weight: 700;
        font-size: 20px;
        margin-bottom: 15px;
    }

    .points-info {
        color: #333;
        margin-bottom: 15px;
        line-height: 1.6;
    }

    .discount-calculation {
        background: rgba(255, 255, 255, 0.8);
        padding: 15px;
        border-radius: 8px;
        margin-top: 15px;
        border-left: 4px solid #ff9800;
    }

    /* ===== ORDERS TABLE ===== */
    .orders-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    .orders-table thead {
        background: #5d33fb;
        color: #fff;
    }

    .orders-table th {
        padding: 14px;
        text-align: left;
        font-weight: 600;
        font-size: 14px;
    }

    .orders-table td {
        padding: 14px;
        border-bottom: 1px solid #e0e0e0;
    }

    .orders-table tbody tr {
        transition: all 0.3s ease;
    }

    .orders-table tbody tr:hover {
        background: #f9f9f9;
    }

    /* ===== STATUS BADGES ===== */
    .status-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-completed {
        background: #d4edda;
        color: #155724;
    }

    .status-processing {
        background: #cfe2ff;
        color: #084298;
    }

    .status-pending {
        background: #fff3cd;
        color: #664d03;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #842029;
    }

    /* ===== ACTION BUTTONS ===== */
    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-view {
        background: #17a2b8;
        color: #fff;
    }

    .btn-view:hover {
        background: #138496;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .btn-track {
        background: #28a745;
        color: #fff;
    }

    .btn-track:hover {
        background: #218838;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    /* ===== EMPTY STATE ===== */
    .empty-orders {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-orders-icon {
        font-size: 72px;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-orders h3 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .empty-orders p {
        color: #666;
        margin-bottom: 30px;
    }

    /* ===== ACTION BUTTONS ===== */
    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 30px;
    }

    .btn-primary-action {
        padding: 12px 28px;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary-action.primary {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .btn-primary-action.primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.4);
        color: #fff;
    }

    .btn-primary-action.secondary {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .btn-primary-action.secondary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(23, 162, 184, 0.4);
        color: #fff;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .orders-page {
            padding: 10px 0;
        }

        .orders-hero {
            padding: 25px 15px;
            margin-bottom: 25px;
        }

        .orders-hero h1 {
            font-size: 24px;
        }

        .orders-hero p {
            font-size: 14px;
        }

        .orders-card {
            padding: 20px;
            margin-bottom: 20px;
        }

        .orders-card h2 {
            font-size: 22px;
        }

        .stats-grid {
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
        }

        .stat-value {
            font-size: 28px;
        }

        .points-section {
            padding: 20px;
        }

        .points-header {
            font-size: 18px;
        }

        .orders-table {
            font-size: 12px;
        }

        .orders-table th,
        .orders-table td {
            padding: 10px;
        }

        .btn-action {
            padding: 5px 10px;
            font-size: 12px;
        }

        .action-buttons {
            gap: 10px;
        }

        .btn-primary-action {
            padding: 10px 20px;
            font-size: 14px;
            flex: 1;
            min-width: 140px;
        }
    }

    @@media (max-width: 576px) {
        .orders-hero h1 {
            font-size: 20px;
        }

        .orders-hero p {
            font-size: 13px;
        }

        .orders-card {
            padding: 15px;
            margin-bottom: 15px;
        }

        .orders-card h2 {
            font-size: 18px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .stat-box {
            padding: 15px;
        }

        .stat-value {
            font-size: 24px;
        }

        .stat-label {
            font-size: 13px;
        }

        .stat-description {
            font-size: 11px;
        }

        .points-section {
            padding: 15px;
            margin-bottom: 20px;
        }

        .points-header {
            font-size: 16px;
        }

        .discount-calculation {
            padding: 12px;
        }

        .orders-table {
            font-size: 11px;
            display: block;
            overflow-x: auto;
        }

        .orders-table th,
        .orders-table td {
            padding: 8px;
        }

        .btn-action {
            padding: 4px 8px;
            font-size: 11px;
        }

        .action-buttons {
            gap: 8px;
            flex-direction: column;
        }

        .btn-primary-action {
            width: 100%;
            padding: 10px 16px;
            font-size: 13px;
        }

        .empty-orders {
            padding: 40px 15px;
        }

        .empty-orders-icon {
            font-size: 56px;
        }
    }
</style>

<div class="orders-page">
    <div class="container">
        <!-- Hero Section -->
        <div class="orders-hero">
            <h1>📦 Vaše Objednávky</h1>
            <p>Sledujte stav svojich objednávok a spravujte svoje body vernostného programu</p>
        </div>

        <!-- Points & Discount Section -->
        <div class="orders-card">
            <h2>⭐ Vaše Bonusové Body a Zľavy</h2>

            <div class="stats-grid">
                <div class="stat-box" style="background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%); box-shadow: 0 4px 15px rgba(255, 215, 0, 0.2);">
                    <div class="stat-value" style="color: #ff9800;">245</div>
                    <div class="stat-label" style="color: #333;">Aktuálne Body</div>
                    <div class="stat-description" style="color: #666;">Zbierajte body za nákupy</div>
                </div>

                <div class="stat-box" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);">
                    <div class="stat-value" style="color: #fff;">€24.50</div>
                    <div class="stat-label" style="color: #fff;">Dostupná Zľava</div>
                    <div class="stat-description" style="color: rgba(255,255,255,0.9);">100 bodov = €10 zľava</div>
                </div>

                <div class="stat-box" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); box-shadow: 0 4px 15px rgba(40, 167, 69, 0.2);">
                    <div class="stat-value" style="color: #fff;">€252.30</div>
                    <div class="stat-label" style="color: #fff;">Celkový Nákup</div>
                    <div class="stat-description" style="color: rgba(255,255,255,0.9);">Spolu za všetky objednávky</div>
                </div>
            </div>

            <!-- Points Information -->
            <div class="points-section">
                <div class="points-header">💡 Ako Funguje Vernostný Program?</div>
                <div class="points-info">
                    <strong>Zbierajte Body:</strong> Za každých €10, ktoré utratíte, získate <strong>1 bod</strong>.<br>
                    <strong>Vymieňajte si Body:</strong> <strong>100 bodov = €10 zľava</strong> na ďalší nákup.<br>
                    <strong>Automatická Úhrada:</strong> Bodami sa dá platiť priamo pri objednávke v čase checkout.
                </div>

                <div class="discount-calculation">
                    <strong style="color: #ff9800;">📊 Vaša Kalkulácia Zľavy:</strong><br>
                    245 bodov ÷ 100 = <strong>2 balíčky</strong> po €10 = <strong>€24.50 dostupnej zľavy</strong><br>
                    <small style="color: #999;">Zvyšok: 45 bodov do ďalšej zľavy (potrebujete 55 bodov)</small>
                </div>
            </div>
        </div>

        <!-- Orders Table Section -->
        <div class="orders-card">
            <h2>📋 História Objednávok</h2>

            <div style="overflow-x: auto;">
                <table class="orders-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Dátum</th>
                            <th>Produkty</th>
                            <th>Ks</th>
                            <th>Zľava</th>
                            <th>Suma</th>
                            <th>Body</th>
                            <th>Stav</th>
                            <th>Akcie</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>001</td>
                            <td>22.02.2026</td>
                            <td>BalanceOil, Zinobiotic</td>
                            <td><strong>2</strong></td>
                            <td><span style="color: #28a745; font-weight: 700;">-€9.90</span></td>
                            <td><strong>€94.90</strong></td>
                            <td><span style="background: #ffd700; padding: 2px 6px; border-radius: 4px; font-weight: 700;">+9</span></td>
                            <td><span class="status-badge status-completed">✓ Zaplatené</span></td>
                            <td>
                                <a href="#" class="btn-action btn-view" title="Zobraziť detaily"><i class="fa fa-eye"></i> Detail</a>
                            </td>
                        </tr>
                        <tr>
                            <td>002</td>
                            <td>15.02.2026</td>
                            <td>CollagenBoozt</td>
                            <td><strong>1</strong></td>
                            <td><span style="color: #28a745; font-weight: 700;">-€5.85</span></td>
                            <td><strong>€58.50</strong></td>
                            <td><span style="background: #ffd700; padding: 2px 6px; border-radius: 4px; font-weight: 700;">+5</span></td>
                            <td><span class="status-badge status-completed">✓ Zaplatené</span></td>
                            <td>
                                <a href="#" class="btn-action btn-view" title="Zobraziť detaily"><i class="fa fa-eye"></i> Detail</a>
                            </td>
                        </tr>
                        <tr>
                            <td>003</td>
                            <td>05.02.2026</td>
                            <td>ZinzinoXtend, BalanceOil</td>
                            <td><strong>2</strong></td>
                            <td><span style="color: #28a745; font-weight: 700;">-€9.90</span></td>
                            <td><strong>€98.90</strong></td>
                            <td><span style="background: #ffd700; padding: 2px 6px; border-radius: 4px; font-weight: 700;">+9</span></td>
                            <td><span class="status-badge status-processing">⏳ Spracovávanie</span></td>
                            <td>
                                <a href="#" class="btn-action btn-track" title="Sledovať"><i class="fa fa-map-marker"></i> Sledovať</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Information Cards -->
        <div class="orders-card">
            <h2>ℹ️ Informácie o Spracovaní Objednávok</h2>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 20px;">
                <div style="background: #e7f3ff; border-left: 4px solid #17a2b8; padding: 15px; border-radius: 8px;">
                    <strong style="color: #17a2b8;">✓ Zaplatené</strong>
                    <p style="margin: 8px 0 0 0; color: #333; font-size: 13px;">Objednávka bola úspešne zaplatená a spracovaná. Môže byť na ceste alebo už doručená.</p>
                </div>

                <div style="background: #cfe2ff; border-left: 4px solid #084298; padding: 15px; border-radius: 8px;">
                    <strong style="color: #084298;">⏳ Spracovávanie</strong>
                    <p style="margin: 8px 0 0 0; color: #333; font-size: 13px;">Objednávka je v procese prípravy. Čoskoro bude poslané na doručenie.</p>
                </div>

                <div style="background: #fff3cd; border-left: 4px solid #664d03; padding: 15px; border-radius: 8px;">
                    <strong style="color: #664d03;">⏸️ Čakajúca</strong>
                    <p style="margin: 8px 0 0 0; color: #333; font-size: 13px;">Objednávka čaká na potvrdenie platby alebo na dostupnosť produktov.</p>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="orders-card">
            <div class="action-buttons">
                <a href='@Url.Action("Kosik","Home")' class="btn-primary-action primary">
                    <i class="fa fa-shopping-cart"></i> Pokračovať v Nákupe
                </a>
                <a href='@Url.Action("Produkty","Home")' class="btn-primary-action secondary">
                    <i class="fa fa-box"></i> Všetky Produkty
                </a>
                <a href='@Url.Action("Member","Home")' class="btn-primary-action secondary">
                    <i class="fa fa-user"></i> Späť na Profil
                </a>
            </div>
        </div>
    </div>
</div>

@{
    // Stop timer and measure memory after view rendered
    _viewTimer.Stop();
    var _memAfter = GC.GetTotalMemory(false);
    var _memDelta = _memAfter - _memBefore;

    // Log server-side render time and memory delta for diagnostics
    try
    {
        Trace.TraceInformation($"[Objednavky.cshtml] View render time: {_viewTimer.ElapsedMilliseconds} ms; Memory delta: {_memDelta} bytes");
    }
    catch { }
}
<!-- Server-side view render: @(_viewTimer.ElapsedMilliseconds) ms; memory delta: @(_memDelta) bytes -->





