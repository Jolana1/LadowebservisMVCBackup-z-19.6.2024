@using LadowebservisMVC.Util

@{
    // Track IDs to avoid rendering duplicate entries
    var seenIds = new System.Collections.Generic.HashSet<string>(System.StringComparer.OrdinalIgnoreCase);
}

<style>
    /* ========== MAIN CONTAINER ========== */
    .kosik-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ========== HERO HEADER ========== */
    .kosik-hero {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        padding: 40px 20px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(93, 51, 251, 0.3);
    }

    .kosik-hero h2 {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 20px 0;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        line-height: 1.6;
    }

    /* ========== DISCOUNT NOTICE ========== */
    .discount-notice {
        background: linear-gradient(135deg, #ffeb3b 0%, #ffc107 100%);
        color: #2c3e50;
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
        text-align: center;
    }

    .discount-notice code {
        background: #fff;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 700;
        color: #5d33fb;
        font-size: 16px;
    }

    /* ========== CARD SECTIONS ========== */
    .kosik-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-bottom: 30px;
    }

    .kosik-card h3 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 25px;
        font-size: 22px;
    }

    /* ========== PRODUCT CARDS ========== */
    .product-card {
        position: relative;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #fff;
    }

    .product-card.in-cart {
        border-color: #28a745;
        background: linear-gradient(135deg, #f0fff4 0%, #e8f5e9 100%);
        box-shadow: 0 4px 15px rgba(40, 167, 69, 0.15);
    }

    .product-card:hover {
        border-color: #5d33fb;
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.15);
        transform: translateY(-3px);
    }

    .product-card.in-cart:hover {
        border-color: #28a745;
        box-shadow: 0 8px 20px rgba(40, 167, 69, 0.25);
    }

    .product-qty-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        border: 2px solid #fff;
        z-index: 5;
    }

    .product-in-cart-label {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        z-index: 4;
    }

    .product-card img {
        max-width: 100%;
        max-height: 120px;
        width: auto;
        height: auto;
        object-fit: contain;
        margin: 0 auto;
    }

    .product-card h4 {
        color: #2c3e50;
        font-size: 16px;
        font-weight: 600;
        margin: 15px 0 10px;
    }

    .product-card p {
        color: #28a745;
        font-size: 20px;
        font-weight: 700;
        margin: 10px 0;
    }

    /* ========== BUTTONS ========== */
    .btn-detail {
        background: #17a2b8;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-detail:hover {
        background: #138496;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .btn-add-cart {
        background: #5d33fb;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover {
        background: #4a2fb5;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .product-heart {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 10;
    }

    .product-heart .fa-heart {
        font-size: 20px;
        color: #e25555;
        transition: all 0.3s ease;
    }

    .product-heart:hover .fa-heart {
        transform: scale(1.2);
    }

    /* ========== CART REVIEW ========== */
    .cart-item {
        border: 2px solid #f0f0f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

    .cart-item:hover {
        border-color: #5d33fb;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.1);
    }

    .cart-item-discount {
        background: #e7f3ff;
        border-color: #28a745;
    }

    .cart-item img {
        max-width: 120px;
        max-height: 120px;
        object-fit: contain;
        border-radius: 8px;
    }

    .discount-badge {
        display: inline-block;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 10px;
    }

    .price-original {
        text-decoration: line-through;
        color: #999;
        margin-right: 8px;
    }

    .price-discounted {
        color: #28a745;
        font-weight: 700;
    }

    /* ========== TOTALS ========== */
    .cart-totals {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
    }

    .cart-totals .row {
        margin-bottom: 10px;
        font-size: 16px;
    }

    .cart-totals .row:last-child {
        border-top: 2px solid #5d33fb;
        padding-top: 15px;
        margin-top: 15px;
        font-size: 20px;
        font-weight: 700;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .kosik-hero h2 {
            font-size: 18px;
        }

        .kosik-card {
            padding: 20px;
        }

        .cart-item {
            padding: 15px;
        }

        .cart-item img {
            max-width: 80px;
            max-height: 80px;
        }
    }

    /* ========== ALERT STYLES ========== */
    .alert-info {
        background: #e7f3ff;
        border: 2px solid #5d33fb;
        border-radius: 8px;
        padding: 20px;
    }

    .alert-info h4 {
        color: #5d33fb;
        margin-top: 0;
    }

    /* Fly-to-cart image animation */
    .lws-fly-img {
        position: absolute !important;
        pointer-events: none;
        z-index: 9999;
        border-radius: 6px;
        transition: transform 0.8s ease-in-out, opacity 0.8s ease-in-out;
        opacity: 1;
        will-change: transform, opacity;
    }

    /* ========== FOOTER BUTTONS ========== */
    .footer-action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .footer-btn {
        padding: 14px 32px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .footer-btn-primary {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .footer-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.4);
        color: #fff;
    }

    .footer-btn-secondary {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .footer-btn-secondary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(23, 162, 184, 0.4);
        color: #fff;
    }
</style>

<div class="kosik-container">

    <!-- Hero Header -->
    <div class="kosik-hero">
        <h2>
            🛒 Košík - Skontrolujte si produkty a dokončite objednávku<br>
            <small style="font-size: 16px; opacity: 0.9;">Môžete pridávať, upravovať množstvo alebo odstraňovať položky</small>
        </h2>

        <div class="discount-notice">
            🎉 Nezabudnite! Pri platbe použite kód <code>NOVYROK26</code> a získajte 10% zľavu na vybrané produkty
        </div>



        <!-- Navigation Buttons -->
        <div class="text-center mt-4">
            <a href="@Url.Action("Login","Home")" class="btn btn-light me-2 mb-2">
                <i class="fa fa-user"></i> Prihlásenie
            </a>
            <a href='@Url.Action("Favorites","Home")' class="btn btn-light me-2 mb-2">
                <i class="fa fa-heart"></i> Obľúbené
            </a>
            <a href='@Url.Action("Zdravie","Home", new { area = "Ladowebservis" })' class="btn btn-light me-2 mb-2">
                <i class="fa fa-home"></i> Späť na úvod
            </a>
            <button type="button" class="btn btn-light mb-2" onclick="openSideCart()">
                <i class="fa fa-shopping-cart"></i> Skontrolovať košík
            </button>
        </div>
    </div>
    <!-- Cart Review Section -->
    <div class="kosik-card">
        <h3>🛍️ Položky v košíku</h3>

        <div id="cartReviewList" class="mb-4">
            <!-- items rendered by JS -->
        </div>

        <!-- Cart Totals -->
        <div class="cart-totals" id="cartTotalsSection" style="display: none;">
            <div class="row">
                <div class="col text-end">Medzisúčet:</div>
                <div class="col-auto"><strong id="cartSubtotal">€0.00</strong></div>
            </div>
            <div class="row" id="discountRow" style="display: none;">
                <div class="col text-end" style="color:#28a745;">Zľava 10% (na vybrané produkty):</div>
                <div class="col-auto" style="color:#28a745;"><strong id="cartDiscount">-€0.00</strong></div>
            </div>
            <div class="row" id="shippingRow" style="display: none;">
                <div class="col text-end">Doprava <span id="cartShippingMethodLabel" class="text-muted" style="font-size:13px;"></span>:</div>
                <div class="col-auto"><strong id="cartShippingFee">€0.00</strong></div>
            </div>
            <div class="row">
                <div class="col text-end"><strong>Celková suma:</strong></div>
                <div class="col-auto"><strong id="cartTotal" style="color:#5d33fb; font-size: 24px;">€0.00</strong></div>
            </div>
        </div>

        <div class="text-center mt-4">
            <button id="clear-cart-btn" class="btn btn-danger btn-lg">
                <i class="fa fa-trash"></i> Vyprázdniť košík
            </button>

        </div>

        <!-- Shipping + Order (bank transfer) -->
        <div class="alert alert-info mt-4" style="border-color:#17a2b8;">
            <h4><i class="fa fa-truck"></i> Doprava a objednávka</h4>
            <p class="mb-3">Vyberte spôsob dopravy a odošlite objednávku (bankový prevod). Po odoslaní dostanete e-mail so súhrnom.</p>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="lwsShippingMethodPage">Doprava</label>
                        <select id="lwsShippingMethodPage" class="form-control">
                            <option value="zasielkovna">Zásielkovňa / Packeta (výdajné miesto)</option>
                            <option value="courier">Kuriér na adresu</option>
                            <option value="dpd-courier">DPD kuriér na adresu</option>
                            <option value="dpd-pickup">DPD odberné miesto</option>
                        </select>
                        <small id="shippingMethodPriceNote" class="text-muted" style="display:block; margin-top:6px;">Cena dopravy sa prepočíta podľa zvolenej služby a hodnoty košíka.</small>
                    </div>
                    <div id="lwsZasielkovnaPickupWrapPage" class="form-group" style="display:none;">
                        <label for="lwsZasielkovnaPickupPointPage" id="pickupPointLabelPage">Výdajné miesto</label>
                        <button id="lwsPickZasielkovnaBtnPage" type="button" class="btn btn-info" style="width:100%; font-weight:700; margin-bottom: 10px;">
                            Vybrať výdajné miesto
                        </button>
                        <input id="lwsZasielkovnaPickupPointPage" type="text" class="form-control" placeholder="Kód výdajného miesta" style="margin-bottom: 8px;" />
                        <input id="lwsZasielkovnaPickupPointNamePage" type="text" class="form-control" placeholder="Názov / adresa výdajného miesta" />
                        <small id="pickupPointHelpPage" class="text-muted">Vyplní sa po výbere vo widgete; dočasne môžete zadať kód a názov ručne.</small>
                    </div>

                    <div id="lwsCourierAddressWrapPage" class="form-group" style="display:none;">
                        <label>Doručovacia adresa (kuriér)</label>
                        <input id="lwsShipAddr1Page" type="text" class="form-control" placeholder="Ulica a číslo" style="margin-bottom: 8px;" />
                        <input id="lwsShipAddr2Page" type="text" class="form-control" placeholder="Byt / poschodie / poznámka (voliteľné)" style="margin-bottom: 8px;" />
                        <div class="row">
                            <div class="col-md-7" style="margin-bottom: 8px;">
                                <input id="lwsShipCityPage" type="text" class="form-control" placeholder="Mesto" />
                            </div>
                            <div class="col-md-5" style="margin-bottom: 8px;">
                                <input id="lwsShipZipPage" type="text" class="form-control" placeholder="PSČ" />
                            </div>
                        </div>
                        <input id="lwsShipCountryPage" type="text" class="form-control" placeholder="Krajina (napr. Slovensko)" />
                    </div>
                </div>

                <div class="col-md-6">
                    @using (Html.BeginForm("PlaceOrder", "Home", FormMethod.Post, new { id = "placeOrderForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CartJson" id="cartJsonInputPlaceOrder" value="" />
                        <input type="hidden" name="PaymentMethod" value="bank" />
                        <input type="hidden" name="ShippingMethod" id="shippingMethodInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPoint" id="zasielkovnaPickupInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointName" id="zasielkovnaPickupNameInput" value="" />
                        <input type="hidden" name="PickupPointDetailsJson" id="pickupPointDetailsJsonInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointJson" id="zasielkovnaPickupJsonInput" value="" />

                        <input type="hidden" name="ShippingAddressLine1" id="shippingAddressLine1Input" value="" />
                        <input type="hidden" name="ShippingAddressLine2" id="shippingAddressLine2Input" value="" />
                        <input type="hidden" name="ShippingCity" id="shippingCityInput" value="" />
                        <input type="hidden" name="ShippingZip" id="shippingZipInput" value="" />
                        <input type="hidden" name="ShippingCountry" id="shippingCountryInput" value="" />

                        <div class="form-group">
                            <label for="name_placeorder">Meno</label>
                            <input id="name_placeorder" name="Name" type="text" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label for="email_placeorder">Email</label>
                            <input id="email_placeorder" name="Email" type="email" class="form-control" required />
                        </div>
                        <button id="placeOrderSubmitBtn" type="submit" class="btn btn-primary btn-lg" style="width:100%;">
                            <i class="fa fa-envelope"></i> Odoslať objednávku (bankový prevod)
                        </button>
                        <div id="placeOrderHelp" class="text-muted" style="margin-top:10px; font-size: 13px; line-height: 1.45;">
                            Po odoslaní zobrazíme potvrdenie objednávky a pošleme vám e‑mail so súhrnom a ďalšími krokmi.
                            Skontrolujte aj priečinok SPAM.
                        </div>
                        <div id="placeOrderStatus" class="alert alert-info" style="display:none; margin-top:12px;">
                            Objednávku odosielame… Prosím počkajte.
                        </div>
                    }

                    @using (Html.BeginForm("StartStripeCheckout", "Home", FormMethod.Post, new { id = "stripeCheckoutForm", style = "margin-top:10px;" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CartJson" id="cartJsonInputStripeCheckout" value="" />
                        <input type="hidden" name="Name" id="name_stripe_checkout" value="" />
                        <input type="hidden" name="Email" id="email_stripe_checkout" value="" />
                        <input type="hidden" name="PaymentMethod" value="stripe" />
                        <input type="hidden" name="ShippingMethod" id="shippingMethodInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPoint" id="zasielkovnaPickupInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointName" id="zasielkovnaPickupNameInputStripe" value="" />
                        <input type="hidden" name="PickupPointDetailsJson" id="pickupPointDetailsJsonInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointJson" id="zasielkovnaPickupJsonInputStripe" value="" />

                        <input type="hidden" name="ShippingAddressLine1" id="shippingAddressLine1InputStripe" value="" />
                        <input type="hidden" name="ShippingAddressLine2" id="shippingAddressLine2InputStripe" value="" />
                        <input type="hidden" name="ShippingCity" id="shippingCityInputStripe" value="" />
                        <input type="hidden" name="ShippingZip" id="shippingZipInputStripe" value="" />
                        <input type="hidden" name="ShippingCountry" id="shippingCountryInputStripe" value="" />
                        <!-- Stripe Buy Button -->
                        <div class="text-center my-3">
                            <stripe-buy-button buy-button-id="buy_btn_1SgujHHrPMzQ1ua8771vUUL4"
                                               publishable-key="pk_live_51P80kcHrPMzQ1ua8JUHSe4iUQ9sLHonQMmFzwyRKnq2xTpB6mhuJVc4OdBKa04BJzpsjjliSrBoNnftkBxwntFF300mePdWSx3">
                            </stripe-buy-button>
                        </div>
                        @*<button type="submit" class="btn btn-success btn-lg" style="width:100%; font-weight:800;">
                                <i class="fa fa-credit-card"></i> Prejsť k platbe cez Stripe
                            </button>*@
                        <small class="text-muted">Po kliknutí prejdete k rýchlemu platobnému linku cez Stripe a následne po dokončení platby odošleme e‑mail s potvrdením objednávky.</small>
                        <div id="stripeOrderStatus" class="alert alert-info" style="display:none; margin-top:12px;">
                            Pripravujeme platobný link… Prosím počkajte.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Payment Instructions -->
        <div class="alert alert-info mt-4">
            <h4><i class="fa fa-credit-card"></i> Postup platby</h4>
            <p>
                Po kliknutí na tlačidlo <strong>"Prejsť k platbe"</strong> budete presmerovaní na zabezpečenú platobnú bránu Stripe, kde si:
            </p>
            <ol>
                <li>Upravíte produkty a množstvá</li>
                <li>Vyplníte dodaciu adresu</li>
                <li>Vložíte propagačný kód <code>NOVYROK26</code> pre 10% zľavu</li>
                <li>Dokončíte platbu</li>
            </ol>
            <p class="mb-0"><strong>Ďakujeme za váš nákup a želáme pevné zdravie! 💚</strong></p>
        </div>

        <!-- Loyalty Points Program -->
        <div class="alert alert-info mt-4" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-color: #28a745;">
            <h4 style="color: #28a745;"><i class="fa fa-star"></i> 🎁 Zarábajte Body za Nákupy</h4>
            <p>
                <strong>Každý nákup = Body do Vášho Konta!</strong>
            </p>
            <ul style="margin-bottom: 15px;">
                <li><strong>1% z každého nákupu</strong> – Automaticky ako body v Vašom účte</li>
                <li><strong>Príklad:</strong> Pri nákupe za 100€ získate 10€ v bodoch</li>
                <li><strong>Bez limitu:</strong> Zbierajte body na každom nákupe</li>
                <li><strong>Jednoduché:</strong> Body sa pripocítajú po platbe automaticky</li>
            </ul>

            <p style="margin-bottom: 15px;">
                <strong>Ako Používať Body?</strong>
            </p>
            <ol style="margin-bottom: 15px;">
                <li><strong>Zaregistrujte sa</strong> – Vytvorte si svoj bezplatný účet</li>
                <li><strong>Robte nákupy</strong> – Každý nákup Vám prinesie body</li>
                <li><strong>Uplatnite body</strong> – Použite svoje body pri ďalšom nákupe ako zľavu</li>
                <li><strong>Šetrite peniaze</strong> – Body sa počítajú ako priama zľava na Vaš nákup</li>
            </ol>

            <div style="background: rgba(40, 167, 69, 0.1); padding: 15px; border-radius: 8px; border-left: 4px solid #28a745; margin-bottom: 15px;">
                <p style="margin: 0; color: #1b5e20;"><strong>💡 Tip:</strong> Body sú prístupné len pre zaregistrovaných zákazníkov. <a href='@Url.Action("Registracia","Home")' style="color: #28a745; font-weight: bold; text-decoration: underline;">Zaregistrujte sa teraz</a> a začnite zbierať body!</p>
            </div>

            <p class="mb-0" style="color: #555; font-size: 14px;">
                <i class="fa fa-info-circle" style="color: #28a745;"></i>
                Body sa počítajú automaticky po úspešnom zaplatení Vašej objednávky. Bez dodatočných krokov, bez registrácie kódu – všetko prebieha automaticky! 🚀
            </p>
        </div>

        <!-- Oriflame + IT Services Info -->
        <div class="alert alert-info">
            <h4><i class="fa fa-shopping-bag"></i> Oriflame produkty a IT služby</h4>
            <p>
                <strong>Oriflame kozmetika:</strong>
            </p>
            <ul>
                <li>Prejdite na <strong>Partnery → Oriflame katalóg</strong> v menu</li>
                <li>Alebo napíšte zoznam produktov na: <a href="mailto:info@ladowebservis.sk">info@ladowebservis.sk</a></li>
            </ul>
            <p>
                <strong>IT služby (oprava PC, web, software):</strong><br>
                Napíšte na: <a href="mailto:podpora@ladowebservis.sk">podpora@ladowebservis.sk</a>
            </p>
        </div>

        <!-- Payment Help Image -->
        <div class="text-center">
            <p class="small text-muted">Potrebujete pomoc s rýchlou platbou cez Stripe? Kliknite na obrázok:</p>
            <a data-fancybox="payment-help" data-caption="Postup platby" href="@Url.Content("~/Image/Postup platby.png")">
                <img src="@Url.Content("~/Image/Postup platby.png")" alt="Postup platby" class="img-thumbnail" style="max-width:150px;cursor:pointer;" />
            </a>
        </div>
    </div>
    <!-- Available Products Section -->
    <div class="kosik-card">
        <h3>📦 Dostupné produkty <span id="productCount" style="color: #999; font-weight: 400; font-size: 16px;">(0 produktov)</span></h3>

        <!-- Search Products -->
        <div style="margin-bottom: 25px;">
            <div class="input-group">
                <span class="input-group-text" style="background: #5d33fb; border: none;">
                    <i class="fa fa-search" style="color: #fff;"></i>
                </span>
                <input type="text" id="productSearch" class="form-control" placeholder="Hľadať produkt podľa názvu..."
                       style="border-left: none; border-color: #5d33fb;">
            </div>
        </div>

        <p style="color: #666; margin-bottom: 25px;">
            <i class="fa fa-lightbulb" style="color: #ff9800;"></i>
            <strong>Tip:</strong> Produkty s <span style="color: #28a745; font-weight: 700;">zeleným rámom</span> sú už v Vašom košíku. Kliknite na <strong>+</strong> alebo <strong>-</strong> pre zmenu množstva.
        </p>
        <div class="row" id="productsContainer">
            <!-- Products will be rendered here -->
        </div>
    </div>



    <!-- Footer Section with Action Buttons -->
    <div style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); padding: 40px 20px; border-radius: 12px; text-align: center; margin-top: 40px;">
        <h3 style="color: #5d33fb; margin-bottom: 15px; font-size: 24px; font-weight: 700;">📦 Táto Sekcia sa bude rozširovať o nové produkty a služby</h3>
        <p style="color: #555; margin-bottom: 30px; font-size: 16px;">Ďakujeme za pochopenie a dôveru v naše produkty!</p>

        <div class="footer-action-buttons">
            <a href="@Url.Action("Produkty","Home")" class="footer-btn footer-btn-primary">
                <i class="fa fa-shopping-bag"></i> Pozrieť Produkty
            </a>
            <button type="button" class="footer-btn footer-btn-secondary" onclick="openSideCart()">
                <i class="fa fa-eye"></i> Skontrolovať Košík
            </button>
            <a href='@Url.Action("Zdravie","Home", new { area = "Ladowebservis" })' class="footer-btn footer-btn-primary">
                <i class="fa fa-home"></i> Späť na Domov
            </a>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function openSideCart() {
            try {
                var cart = document.getElementById('side-cart');
                var overlay = document.getElementById('cart-overlay');
                if (!cart || !overlay) return;
                cart.classList.add('open');
                overlay.classList.add('open');
                cart.setAttribute('aria-hidden', 'false');
                overlay.setAttribute('aria-hidden', 'false');
                cart.focus();
            } catch (e) { }
        }

        (function () {
            var STORAGE_KEY = 'lws_cart_v1';

            var shippingLabels = {
                'zasielkovna': 'Zásielkovňa / Packeta',
                'packeta': 'Zásielkovňa / Packeta',
                'courier': 'Kuriér na adresu',
                'dpd-courier': 'DPD kuriér',
                'dpd-pickup': 'DPD odberné miesto'
            };

            var shippingRateTables = {
                'zasielkovna': [
                    { minTotal: 0, price: 3.90 },
                    { minTotal: 50, price: 2.90 },
                    { minTotal: 80, price: 0.00 }
                ],
                'courier': [
                    { minTotal: 0, price: 4.90 },
                    { minTotal: 70, price: 2.90 },
                    { minTotal: 100, price: 0.00 }
                ],
                'dpd-courier': [
                    { minTotal: 0, price: 4.60 },
                    { minTotal: 70, price: 3.20 },
                    { minTotal: 100, price: 0.00 }
                ],
                'dpd-pickup': [
                    { minTotal: 0, price: 3.60 },
                    { minTotal: 70, price: 2.40 },
                    { minTotal: 100, price: 0.00 }
                ]
            };

            function loadShipping() {
                try {
                    return JSON.parse(localStorage.getItem('lws_shipping_v1') || '{}') || {};
                } catch (e) {
                    return {};
                }
            }

            function saveShipping(ship) {
                try { localStorage.setItem('lws_shipping_v1', JSON.stringify(ship || {})); } catch (e) { }
            }

            window.lwsRefreshCheckoutShipping = function () {
                try {
                    hydrateOrderFormFromStorage();
                    renderCartReview();
                    var methodSel = document.getElementById('lwsShippingMethodPage');
                    var ship = loadShipping();
                    if (methodSel && ship && ship.method) {
                        methodSel.value = ship.method;
                    }
                } catch (e) { }
            };

            function getShippingLabel(method) {
                return shippingLabels[method || ''] || 'Doprava';
            }

            function calculateShippingFee(method, cartTotal) {
                var table = shippingRateTables[method || ''];
                if (!table || !table.length) return 0;
                var fee = 0;
                table.forEach(function (rate) {
                    if (!rate) return;
                    if ((rate.minTotal || 0) <= cartTotal) {
                        fee = typeof rate.price === 'number' ? rate.price : fee;
                    }
                });
                return fee;
            }

            function loadCart() {
                try {
                    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function saveCart(cart) {
                try { localStorage.setItem(STORAGE_KEY, JSON.stringify(cart)); } catch (e) { }
            }

            function getProductPrice(key) {
                var catalog = window.__lws_products || {};
                if (catalog && catalog[key] && catalog[key].Price) return parseFloat(catalog[key].Price) || 0;
                if (catalog) {
                    for (var id in catalog) {
                        if (!catalog.hasOwnProperty(id)) continue;
                        var it = catalog[id];
                        if (it && it.Name === key && it.Price) return parseFloat(it.Price) || 0;
                    }
                }
                return ({ 'BalanceTest': 195.00, 'BalanceOil': 55.00, 'Zinobiotic': 40.00, 'ZinzinoXtend': 44.00, 'CollagenBoozt': 85.00 }[key] || 0);
            }

            function getCartTotals(cart) {
                var subtotal = 0, totalQty = 0, discount = 0;
                Object.keys(cart).forEach(function (k) {
                    var item = cart[k];
                    if (!item || (item.quantity || 0) <= 0) return;
                    var q = item.quantity || 0;
                    totalQty += q;
                    var unit = getProductPrice(k);
                    var line = unit * q;
                    subtotal += line;
                    // 10% discount when line amount > 50€ OR product is ZinzinoXtend
                    var isXtend = (String(k) === '3') || (String(k).toLowerCase() === 'zinzinoxtend');
                    if ((line > 50) || isXtend) {
                        discount += line * 0.10;
                    }
                });
                var total = subtotal - discount;

                var ship = loadShipping();
                var shippingMethod = ship && ship.method ? ship.method : '';
                var shippingFee = calculateShippingFee(shippingMethod, total);

                return {
                    subtotal: subtotal,
                    total: total,
                    discount: discount,
                    totalQty: totalQty,
                    shippingMethod: shippingMethod,
                    shippingLabel: getShippingLabel(shippingMethod),
                    shippingFee: shippingFee,
                    grandTotal: total + shippingFee
                };
            }

            function changeQuantity(id, delta) {
                if (!id || !delta) return;
                var cart = loadCart();
                var item = cart[id];
                if (!item) return;
                var current = item.quantity || 0;
                var next = current + delta;
                if (next <= 0) {
                    delete cart[id];
                } else {
                    item.quantity = next;
                    cart[id] = item;
                }
                saveCart(cart);
                renderProducts();
                renderCartReview();
                if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
            }

            function renderProducts() {
                var catalog = window.__lws_products || {};
                var cart = loadCart();
                var container = document.getElementById('productsContainer');
                var productCount = document.getElementById('productCount');

                if (!container) return;

                container.innerHTML = '';
                var allProducts = [];

                // Build product list from catalog
                if (Array.isArray(catalog)) {
                    allProducts = catalog;
                } else {
                    for (var id in catalog) {
                        if (catalog.hasOwnProperty(id)) {
                            allProducts.push(catalog[id]);
                        }
                    }
                }

                // Render each product
                allProducts.forEach(function (p) {
                    if (!p || !p.Id) return;

                    var id = p.Id.toString().trim();
                    var name = p.Name || 'Unknown';
                    var price = parseFloat(p.Price) || 0;
                    var image = p.Image || '/Image/placeholder.png';

                    var qualifiesForDiscount = (price > 50) || (name && name.toLowerCase && name.toLowerCase() === 'zinzinoxtend') || (id === '3');
                    var discountedPrice = qualifiesForDiscount ? price * 0.9 : price;

                    var cartItem = cart[id];
                    var cartQty = cartItem ? (cartItem.quantity || 0) : 0;
                    var isInCart = cartQty > 0;

                    var col = document.createElement('div');
                    col.className = 'col-12 col-sm-6 col-md-4 col-lg-3 mb-4';
                    col.setAttribute('data-product-id', id);
                    col.setAttribute('data-product-name', name.toLowerCase());

                    var cardClass = 'card p-3 text-center product-card' + (isInCart ? ' in-cart' : '');

                    var html = '<div class="' + cardClass + '">';

                    // In cart label
                    if (isInCart) {
                        html += '<span class="product-in-cart-label"><i class="fa fa-check"></i> V košíku</span>';
                    }

                    // Quantity badge
                    if (isInCart) {
                        html += '<div class="product-qty-badge" title="Počet ks v košíku">' + cartQty + '</div>';
                    }

                    // Discount badge
                    if (qualifiesForDiscount) {
                        html += '<span class="discount-badge" style="position: absolute; top: 10px; left: 10px;">-10% ZĽAVA</span>';
                    }

                    // Heart button
                    html += '<button type="button" class="product-heart" data-id="' + id + '" title="Pridať do obľúbených" aria-label="Pridať do obľúbených">';
                    html += '<i class="fa fa-heart" aria-hidden="true"></i>';
                    html += '</button>';

                    // Image
                    html += '<img src="' + image + '" alt="' + name + '" class="img-fluid mx-auto mb-3" />';

                    // Name
                    html += '<h4>' + name + '</h4>';

                    // Price
                    if (qualifiesForDiscount) {
                        html += '<p>';
                        html += '<span class="price-original">€' + price.toFixed(2) + '</span>';
                        html += '<span class="price-discounted">€' + discountedPrice.toFixed(2) + '</span>';
                        html += '</p>';
                    } else {
                        html += '<p>€' + price.toFixed(2) + '</p>';
                    }

                    // Buttons
                    html += '<div class="mt-auto d-flex gap-2 justify-content-center align-items-center flex-wrap">';

                    if (isInCart) {
                        html += '<div class="btn-group btn-group-sm" role="group">';
                        html += '<button type="button" class="btn btn-outline-success qty-dec-product" data-id="' + id + '" title="Znížiť množstvo">−</button>';
                        html += '<button type="button" class="btn btn-light" disabled>' + cartQty + '</button>';
                        html += '<button type="button" class="btn btn-outline-success qty-inc-product" data-id="' + id + '" title="Zvýšiť množstvo">+</button>';
                        html += '</div>';
                    } else {
                        html += '<button type="button" class="btn btn-sm btn-add-cart add-to-cart" data-id="' + id + '">';
                        html += '<i class="fa fa-cart-plus"></i> Do košíka';
                        html += '</button>';
                    }

                    html += '<a class="btn btn-sm btn-detail" href="/Home/Produkty?q=' + encodeURIComponent(name) + '" title="Zobraziť detail produktu">';
                    html += '<i class="fa fa-info-circle"></i> Detail';
                    html += '</a>';
                    html += '</div>';

                    html += '</div>';
                    col.innerHTML = html;
                    container.appendChild(col);
                });

                // Update product count
                if (productCount) {
                    productCount.textContent = '(' + allProducts.length + ' produktov)';
                }

                // Attach event listeners
                container.querySelectorAll('.add-to-cart').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var id = this.getAttribute('data-id');
                        var cart = loadCart();
                        var item = cart[id];
                        if (!item) {
                            var prodInfo = allProducts.find(function (p) { return p.Id.toString() === id; });
                            cart[id] = { quantity: 1, image: prodInfo ? prodInfo.Image : '' };
                        } else {
                            item.quantity = (item.quantity || 0) + 1;
                        }
                        saveCart(cart);
                        renderProducts();
                        renderCartReview();
                        if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                    });
                });

                container.querySelectorAll('.qty-inc-product').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), 1);
                    });
                });

                container.querySelectorAll('.qty-dec-product').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), -1);
                    });
                });

                container.querySelectorAll('.product-heart').forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var id = this.getAttribute('data-id');
                        var prodInfo = allProducts.find(function (p) { return p.Id.toString() === id; });
                        if (prodInfo) {
                            var favs = JSON.parse(localStorage.getItem('lws_favorites') || '{}');
                            if (favs[id]) {
                                delete favs[id];
                            } else {
                                favs[id] = { name: prodInfo.Name, price: prodInfo.Price, image: prodInfo.Image };
                            }
                            localStorage.setItem('lws_favorites', JSON.stringify(favs));
                            this.classList.toggle('active');
                        }
                    });
                });
            }

            function renderCartReview() {
                var cart = loadCart();
                var container = document.getElementById('cartReviewList');
                if (!container) return;

                container.innerHTML = '';
                var hasItems = false;
                var catalog = window.__lws_products || {};

                Object.keys(cart).forEach(function (k) {
                    var item = cart[k];
                    if (!item || (item.quantity || 0) <= 0) return;
                    hasItems = true;

                    var productInfo = catalog && catalog[k] ? catalog[k] : null;
                    var displayName = productInfo && productInfo.Name ? productInfo.Name : k;
                    var imgSrc = item.image || (productInfo && productInfo.Image) || ('/Image/' + k + '.png');
                    var unitPrice = getProductPrice(k);
                    var qtyVal = item.quantity || 0;
                    var baseLine = unitPrice * qtyVal;
                    var qualifiesForDiscount = (baseLine > 50) || (String(k) === '3') || (displayName && displayName.toLowerCase && displayName.toLowerCase() === 'zinzinoxtend');
                    var discountAmount = qualifiesForDiscount ? baseLine * 0.10 : 0;
                    var lineTotal = baseLine - discountAmount;

                    var itemDiv = document.createElement('div');
                    itemDiv.className = 'cart-item' + (qualifiesForDiscount ? ' cart-item-discount' : '');

                    var html = '<div class="row align-items-center">';
                    html += '<div class="col-md-2 col-4 text-center mb-3 mb-md-0">';
                    html += '<img src="' + imgSrc + '" alt="' + displayName + '" class="img-fluid">';
                    html += '</div>';
                    html += '<div class="col-md-5 col-8 mb-3 mb-md-0">';
                    html += '<h5 style="color:#5d33fb; margin-bottom:10px;">' + displayName + '</h5>';
                    html += '<p class="mb-1"><small>ID: ' + k + '</small></p>';

                    if (qualifiesForDiscount) {
                        html += '<p class="mb-1">';
                        html += 'Cena za ks: <span class="price-original">€' + unitPrice.toFixed(2) + '</span> ';
                        html += '<span class="price-discounted">€' + (unitPrice * 0.9).toFixed(2) + '</span>';
                        html += '<span class="discount-badge">-10%</span>';
                        html += '</p>';
                        html += '<p class="mb-1">Množstvo: <strong>' + qtyVal + '</strong></p>';
                        html += '<p class="mb-0">Suma: <strong style="color:#28a745; font-size:18px;">€' + lineTotal.toFixed(2) + '</strong> ';
                        html += '<small style="color:#999;">(ušetrili ste €' + discountAmount.toFixed(2) + ')</small></p>';
                    } else {
                        html += '<p class="mb-1">Cena za ks: <strong>€' + unitPrice.toFixed(2) + '</strong></p>';
                        html += '<p class="mb-1">Množstvo: <strong>' + qtyVal + '</strong></p>';
                        html += '<p class="mb-0">Suma: <strong style="font-size:18px;">€' + lineTotal.toFixed(2) + '</strong></p>';
                    }

                    html += '</div>';
                    html += '<div class="col-md-5 col-12 text-md-end">';
                    html += '<div class="btn-group mb-2" role="group">';
                    html += '<button type="button" class="btn btn-sm btn-outline-secondary qty-dec" data-id="' + k + '" title="Znížiť množstvo">−</button>';
                    html += '<span class="btn btn-sm btn-light disabled">' + qtyVal + '</span>';
                    html += '<button type="button" class="btn btn-sm btn-outline-secondary qty-inc" data-id="' + k + '" title="Zvýšiť množstvo">+</button>';
                    html += '</div><br>';
                    html += '<a href="/Home/Produkty?q=' + encodeURIComponent(displayName) + '" class="btn btn-sm btn-detail me-2 mb-2"><i class="fa fa-info-circle"></i> Detail</a>';
                    html += '<button type="button" class="btn btn-sm btn-danger remove-item mb-2" data-id="' + k + '"><i class="fa fa-trash"></i> Odstrániť</button>';
                    html += '</div>';
                    html += '</div>';

                    itemDiv.innerHTML = html;
                    container.appendChild(itemDiv);
                });

                // Attach event listeners
                container.querySelectorAll('.qty-dec').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), -1);
                    });
                });

                container.querySelectorAll('.qty-inc').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        changeQuantity(this.getAttribute('data-id'), 1);
                    });
                });

                container.querySelectorAll('.remove-item').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var id = this.getAttribute('data-id');
                        var cartNow = loadCart();
                        if (cartNow && cartNow[id]) {
                            delete cartNow[id];
                            saveCart(cartNow);
                        }
                        renderProducts();
                        renderCartReview();
                        if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                    });
                });

                // Update totals
                var totals = getCartTotals(cart);
                var totalsSection = document.getElementById('cartTotalsSection');
                var subtotalEl = document.getElementById('cartSubtotal');
                var discountEl = document.getElementById('cartDiscount');
                var totalEl = document.getElementById('cartTotal');
                var discountRow = document.getElementById('discountRow');
                var shippingRow = document.getElementById('shippingRow');
                var shippingFeeEl = document.getElementById('cartShippingFee');
                var shippingMethodLabelEl = document.getElementById('cartShippingMethodLabel');

                if (!totalsSection || !subtotalEl || !totalEl || !discountRow || !discountEl) {
                    // Missing totals elements in DOM; avoid crashing the whole page.
                    return;
                }

                if (hasItems) {
                    totalsSection.style.display = 'block';
                    subtotalEl.textContent = '€' + totals.subtotal.toFixed(2);
                    totalEl.textContent = '€' + totals.grandTotal.toFixed(2);

                    if (totals.discount > 0) {
                        discountRow.style.display = 'flex';
                        discountEl.textContent = '-€' + totals.discount.toFixed(2);
                    } else {
                        discountRow.style.display = 'none';
                    }

                    if (shippingRow && shippingFeeEl && shippingMethodLabelEl) {
                        shippingRow.style.display = totals.shippingMethod ? 'flex' : 'none';
                        shippingFeeEl.textContent = '€' + totals.shippingFee.toFixed(2);
                        shippingMethodLabelEl.textContent = totals.shippingMethod ? '(' + totals.shippingLabel + ')' : '';
                    }
                } else {
                    totalsSection.style.display = 'none';
                    container.innerHTML = '<div class="alert alert-warning text-center"><i class="fa fa-shopping-cart"></i> Váš košík je prázdny</div>';
                }

                // Update header cart badge
                if (typeof window.lwsRefreshShippingSummary === 'function') window.lwsRefreshShippingSummary();
                if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
            }

            // Clear cart button
            document.getElementById('clear-cart-btn').addEventListener('click', function () {
                if (confirm('Naozaj chcete vyprázdniť celý košík?')) {
                    localStorage.removeItem(STORAGE_KEY);
                    renderProducts();
                    renderCartReview();
                    if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                }
            });

            // Initial render
            renderProducts();
            renderCartReview();

            // Populate hidden order fields from localStorage
            function hydrateOrderFormFromStorage() {
                try {
                    var cartJson = localStorage.getItem(STORAGE_KEY) || '{}';
                    var cartEl = document.getElementById('cartJsonInputPlaceOrder');
                    if (cartEl) cartEl.value = cartJson;

                    var shipJson = localStorage.getItem('lws_shipping_v1') || '{}';
                    var ship = {};
                    try { ship = JSON.parse(shipJson) || {}; } catch (e) { ship = {}; }

                    var shipMethod = ship.method || '';
                    var pickup = ship.pickupPoint || '';
                    var pickupName = ship.pickupPointName || '';
                    var pickupJson = ship.pickupPointJson || '';

                    var shipMethodEl = document.getElementById('shippingMethodInput');
                    var pickupEl = document.getElementById('zasielkovnaPickupInput');
                    var pickupNameEl = document.getElementById('zasielkovnaPickupNameInput');
                    var pickupJsonEl = document.getElementById('zasielkovnaPickupJsonInput');
                    if (shipMethodEl) shipMethodEl.value = shipMethod;
                    if (pickupEl) pickupEl.value = pickup;
                    if (pickupNameEl) pickupNameEl.value = pickupName;
                    if (pickupJsonEl) pickupJsonEl.value = pickupJson;

                    var a1El = document.getElementById('shippingAddressLine1Input');
                    var a2El = document.getElementById('shippingAddressLine2Input');
                    var cityEl = document.getElementById('shippingCityInput');
                    var zipEl = document.getElementById('shippingZipInput');
                    var countryEl = document.getElementById('shippingCountryInput');
                    if (a1El) a1El.value = ship.addressLine1 || '';
                    if (a2El) a2El.value = ship.addressLine2 || '';
                    if (cityEl) cityEl.value = ship.city || '';
                    if (zipEl) zipEl.value = ship.zip || '';
                    if (countryEl) countryEl.value = ship.country || '';
                } catch (e) { }
            }

            hydrateOrderFormFromStorage();

            // Also hydrate Stripe checkout hidden inputs (re-using the same cart + shipping)
            (function hydrateStripeCheckoutForm() {
                try {
                    var cartJson = localStorage.getItem(STORAGE_KEY) || '{}';
                    var cartEl = document.getElementById('cartJsonInputStripeCheckout');
                    if (cartEl) cartEl.value = cartJson;

                    var nameVal = (document.getElementById('name_placeorder') && document.getElementById('name_placeorder').value) ? document.getElementById('name_placeorder').value : '';
                    var emailVal = (document.getElementById('email_placeorder') && document.getElementById('email_placeorder').value) ? document.getElementById('email_placeorder').value : '';
                    var nameEl = document.getElementById('name_stripe_checkout');
                    var emailEl = document.getElementById('email_stripe_checkout');
                    if (nameEl) nameEl.value = nameVal;
                    if (emailEl) emailEl.value = emailVal;

                    var shipJson = localStorage.getItem('lws_shipping_v1') || '{}';
                    var ship = {};
                    try { ship = JSON.parse(shipJson) || {}; } catch (e) { ship = {}; }

                    var sm = ship.method || '';
                    var pp = ship.pickupPoint || '';
                    var ppName = ship.pickupPointName || '';
                    var ppJson = ship.pickupPointJson || '';

                    var smEl = document.getElementById('shippingMethodInputStripe');
                    var ppEl = document.getElementById('zasielkovnaPickupInputStripe');
                    var ppNameEl = document.getElementById('zasielkovnaPickupNameInputStripe');
                    var ppJsonEl = document.getElementById('zasielkovnaPickupJsonInputStripe');
                    if (smEl) smEl.value = sm;
                    if (ppEl) ppEl.value = pp;
                    if (ppNameEl) ppNameEl.value = ppName;
                    if (ppJsonEl) ppJsonEl.value = ppJson;

                    // keep in sync with user typing
                    var nameInput = document.getElementById('name_placeorder');
                    var emailInput = document.getElementById('email_placeorder');
                    function syncCustomer() {
                        var n = nameInput ? (nameInput.value || '') : '';
                        var e = emailInput ? (emailInput.value || '') : '';
                        if (nameEl) nameEl.value = n;
                        if (emailEl) emailEl.value = e;
                    }
                    if (nameInput) nameInput.addEventListener('input', syncCustomer);
                    if (emailInput) emailInput.addEventListener('input', syncCustomer);
                } catch (e) { }
            })();

            // Shipping / pickup selection (Packeta widget)
            (function initShippingUi() {
                var methodSel = document.getElementById('lwsShippingMethodPage');
                var pickupWrap = document.getElementById('lwsZasielkovnaPickupWrapPage');
                var courierWrap = document.getElementById('lwsCourierAddressWrapPage');
                var pickBtn = document.getElementById('lwsPickZasielkovnaBtnPage');
                var pickupCode = document.getElementById('lwsZasielkovnaPickupPointPage');
                var pickupName = document.getElementById('lwsZasielkovnaPickupPointNamePage');

                var addr1 = document.getElementById('lwsShipAddr1Page');
                var addr2 = document.getElementById('lwsShipAddr2Page');
                var city = document.getElementById('lwsShipCityPage');
                var zip = document.getElementById('lwsShipZipPage');
                var country = document.getElementById('lwsShipCountryPage');

                if (!methodSel) return;

                var pickupLabel = document.getElementById('pickupPointLabelPage');
                var pickupHelp = document.getElementById('pickupPointHelpPage');
                var shippingMethodPriceNote = document.getElementById('shippingMethodPriceNote');

                function loadShip() { return loadShipping(); }
                function saveShip(s) { saveShipping(s); }

                function isPickupMethod(method) {
                    return method === 'zasielkovna' || method === 'packeta' || method === 'dpd-pickup';
                }

                function isCourierMethod(method) {
                    return method === 'courier' || method === 'dpd-courier';
                }

                function refreshShippingHelp(ship) {
                    var method = ship && ship.method ? ship.method : '';
                    var cartTotals = getCartTotals(loadCart());
                    var shippingPrice = calculateShippingFee(method, cartTotals.total);
                    if (shippingMethodPriceNote) {
                        shippingMethodPriceNote.textContent = method
                            ? ('Aktuálna cena pre ' + getShippingLabel(method) + ': €' + shippingPrice.toFixed(2) + '. Cena sa mení podľa hodnoty košíka.')
                            : 'Cena dopravy sa prepočíta podľa zvolenej služby a hodnoty košíka.';
                    }

                    if (typeof window.lwsRefreshShippingSummary === 'function') {
                        window.lwsRefreshShippingSummary();
                    }

                    if (pickupLabel) {
                        pickupLabel.textContent = method === 'dpd-pickup' ? 'Odberné miesto (DPD Pickup)' : 'Výdajné miesto';
                    }
                    if (pickBtn) {
                        pickBtn.textContent = method === 'dpd-pickup' ? 'Zadať / vybrať DPD odberné miesto' : 'Vybrať výdajné miesto';
                        pickBtn.style.display = method === 'dpd-pickup' ? 'none' : '';
                    }
                    if (pickupHelp) {
                        pickupHelp.textContent = method === 'dpd-pickup'
                            ? 'DPD funguje iba ako ručné zadanie odberného miesta. Zadajte kód a názov alebo adresu. Cenu dopravy vidíte okamžite v súhrne košíka.'
                            : 'Vyplní sa po výbere vo widgete; dočasne môžete zadať kód a názov ručne.';
                    }
                }

                function applyToHiddenFields(ship) {
                    try {
                        var shipMethodEl = document.getElementById('shippingMethodInput');
                        var pickupEl = document.getElementById('zasielkovnaPickupInput');
                        var pickupNameEl = document.getElementById('zasielkovnaPickupNameInput');
                        var pickupJsonEl = document.getElementById('zasielkovnaPickupJsonInput');
                        if (shipMethodEl) shipMethodEl.value = ship.method || '';
                        if (pickupEl) pickupEl.value = ship.pickupPoint || '';
                        if (pickupNameEl) pickupNameEl.value = ship.pickupPointName || '';
                        if (pickupJsonEl) pickupJsonEl.value = ship.pickupPointJson || '';

                        var a1El = document.getElementById('shippingAddressLine1Input');
                        var a2El = document.getElementById('shippingAddressLine2Input');
                        var cityEl = document.getElementById('shippingCityInput');
                        var zipEl = document.getElementById('shippingZipInput');
                        var countryEl = document.getElementById('shippingCountryInput');
                        if (a1El) a1El.value = ship.addressLine1 || '';
                        if (a2El) a2El.value = ship.addressLine2 || '';
                        if (cityEl) cityEl.value = ship.city || '';
                        if (zipEl) zipEl.value = ship.zip || '';
                        if (countryEl) countryEl.value = ship.country || '';

                        var shipMethodElS = document.getElementById('shippingMethodInputStripe');
                        var pickupElS = document.getElementById('zasielkovnaPickupInputStripe');
                        var pickupNameElS = document.getElementById('zasielkovnaPickupNameInputStripe');
                        var pickupJsonElS = document.getElementById('zasielkovnaPickupJsonInputStripe');
                        if (shipMethodElS) shipMethodElS.value = ship.method || '';
                        if (pickupElS) pickupElS.value = ship.pickupPoint || '';
                        if (pickupNameElS) pickupNameElS.value = ship.pickupPointName || '';
                        if (pickupJsonElS) pickupJsonElS.value = ship.pickupPointJson || '';

                        var a1ElS = document.getElementById('shippingAddressLine1InputStripe');
                        var a2ElS = document.getElementById('shippingAddressLine2InputStripe');
                        var cityElS = document.getElementById('shippingCityInputStripe');
                        var zipElS = document.getElementById('shippingZipInputStripe');
                        var countryElS = document.getElementById('shippingCountryInputStripe');
                        if (a1ElS) a1ElS.value = ship.addressLine1 || '';
                        if (a2ElS) a2ElS.value = ship.addressLine2 || '';
                        if (cityElS) cityElS.value = ship.city || '';
                        if (zipElS) zipElS.value = ship.zip || '';
                        if (countryElS) countryElS.value = ship.country || '';
                    } catch (e) { }
                }

                function syncUiFromStorage() {
                    var ship = loadShip();
                    if (ship && ship.method) methodSel.value = ship.method;
                    if (pickupWrap) pickupWrap.style.display = (ship && isPickupMethod(ship.method)) ? '' : 'none';
                    if (courierWrap) courierWrap.style.display = (ship && isCourierMethod(ship.method)) ? '' : 'none';
                    if (pickupCode) pickupCode.value = (ship && ship.pickupPoint) ? ship.pickupPoint : '';
                    if (pickupName) pickupName.value = (ship && ship.pickupPointName) ? ship.pickupPointName : '';

                    if (addr1) addr1.value = (ship && ship.addressLine1) ? ship.addressLine1 : '';
                    if (addr2) addr2.value = (ship && ship.addressLine2) ? ship.addressLine2 : '';
                    if (city) city.value = (ship && ship.city) ? ship.city : '';
                    if (zip) zip.value = (ship && ship.zip) ? ship.zip : '';
                    if (country) country.value = (ship && ship.country) ? ship.country : '';
                    applyToHiddenFields(ship);
                    refreshShippingHelp(ship);
                }

                methodSel.addEventListener('change', function () {
                    var ship = loadShip();
                    ship.method = methodSel.value || '';
                    if (!isPickupMethod(ship.method)) {
                        ship.pickupPoint = '';
                        ship.pickupPointName = '';
                        ship.pickupPointJson = '';
                    }
                    if (!isCourierMethod(ship.method)) {
                        ship.addressLine1 = '';
                        ship.addressLine2 = '';
                        ship.city = '';
                        ship.zip = '';
                        ship.country = '';
                    }
                    saveShip(ship);
                    syncUiFromStorage();
                    renderCartReview();
                    if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                });

                function saveCourier() {
                    var ship = loadShip();
                    ship.method = ship.method || methodSel.value || '';
                    ship.addressLine1 = addr1 ? (addr1.value || '') : '';
                    ship.addressLine2 = addr2 ? (addr2.value || '') : '';
                    ship.city = city ? (city.value || '') : '';
                    ship.zip = zip ? (zip.value || '') : '';
                    ship.country = country ? (country.value || '') : '';
                    saveShip(ship);
                    applyToHiddenFields(ship);
                    renderCartReview();
                }

                if (addr1) addr1.addEventListener('input', saveCourier);
                if (addr2) addr2.addEventListener('input', saveCourier);
                if (city) city.addEventListener('input', saveCourier);
                if (zip) zip.addEventListener('input', saveCourier);
                if (country) country.addEventListener('input', saveCourier);

                if (pickBtn) {
                    pickBtn.addEventListener('click', function () {
                        var apiKey = (window.__packetaApiKey || '').toString();
                        if (!apiKey || !window.Packeta || !window.Packeta.Widget) {
                            alert('Widget dopravy nie je načítaný.');
                            return;
                        }
                        window.Packeta.Widget.pick(apiKey, function (point) {
                            if (!point) return;
                            var ship = loadShip();
                            ship.method = 'zasielkovna';
                            ship.pickupPoint = point.id || point.place || point.code || '';
                            ship.pickupPointName = point.name || point.place || point.city || '';
                            ship.pickupPointJson = JSON.stringify(point);
                            saveShip(ship);
                            syncUiFromStorage();
                            renderCartReview();
                            if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                        });
                    });
                }

                if (pickupCode) {
                    pickupCode.addEventListener('input', function () {
                        var ship = loadShip();
                        ship.method = ship.method || 'zasielkovna';
                        ship.pickupPoint = pickupCode.value || '';
                        saveShip(ship);
                        applyToHiddenFields(ship);
                        renderCartReview();
                    });
                }
                if (pickupName) {
                    pickupName.addEventListener('input', function () {
                        var ship = loadShip();
                        ship.method = ship.method || 'zasielkovna';
                        ship.pickupPointName = pickupName.value || '';
                        saveShip(ship);
                        applyToHiddenFields(ship);
                        renderCartReview();
                    });
                }

                // initial
                syncUiFromStorage();
                if (typeof window.lwsSetShippingMethod === 'function' && methodSel && methodSel.value) {
                    window.lwsSetShippingMethod(methodSel.value);
                }
            })();

            // Submit UI feedback
            (function initSubmitFeedback() {
                function onSubmit(formId, statusId, submitBtnId, busyText) {
                    var form = document.getElementById(formId);
                    if (!form) return;
                    form.addEventListener('submit', function () {
                        try {
                            var status = document.getElementById(statusId);
                            if (status) status.style.display = '';
                            var btn = document.getElementById(submitBtnId);
                            if (btn) {
                                btn.disabled = true;
                                btn.innerHTML = busyText;
                            }
                        } catch (e) { }
                    });
                }

                onSubmit('placeOrderForm', 'placeOrderStatus', 'placeOrderSubmitBtn', '<i class="fa fa-spinner fa-spin"></i> Odosielam…');
                onSubmit('stripeCheckoutForm', 'stripeOrderStatus', null, null);
            })();

            // Search functionality - match products by name and ID
            var searchInput = document.getElementById('productSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var searchTerm = this.value.toLowerCase().trim();
                    var productCards = document.querySelectorAll('#productsContainer [data-product-id]');
                    var visibleCount = 0;

                    productCards.forEach(function (card) {
                        var productName = card.getAttribute('data-product-name') || '';
                        var productId = card.getAttribute('data-product-id') || '';
                        var searchableText = (productName + ' ' + productId).toLowerCase();

                        // Show/hide based on search match
                        var matches = !searchTerm || searchableText.indexOf(searchTerm) >= 0;
                        card.style.display = matches ? '' : 'none';

                        if (matches) {
                            visibleCount++;
                        }
                    });

                    // Update product count display
                    var allCount = productCards.length;
                    var productCountEl = document.getElementById('productCount');
                    if (productCountEl) {
                        if (searchTerm) {
                            productCountEl.textContent = '(' + visibleCount + ' z ' + allCount + ' produktov)';
                        } else {
                            productCountEl.textContent = '(' + allCount + ' produktov)';
                        }
                    }
                });
            }
        })();
    </script>
}























































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































