@section scripts {
    <script>
        function openSideCart() {
            try {
                var cart = document.getElementById('side-cart');
                var overlay = document.getElementById('cart-overlay');
                if (!cart || !overlay) return;
                cart.classList.add('open');
                overlay.classList.add('open');
                cart.setAttribute('aria-hidden', 'false');
                overlay.setAttribute('aria-hidden', 'false');
                cart.focus();
            } catch (e) { }
        }

        // Favorites functionality
        (function () {
            var FAVORITES_KEY = 'lws_favorites';

            function loadFavorites() {
                try {
                    return JSON.parse(localStorage.getItem(FAVORITES_KEY) || '{}');
                } catch (e) {
                    return {};
                }
            }

            function saveFavorites(favs) {
                try {
                    localStorage.setItem(FAVORITES_KEY, JSON.stringify(favs));
                } catch (e) { }
            }

            function updateProductFavoriteStatus() {
                var favs = loadFavorites();
                var products = document.querySelectorAll('section.products');

                products.forEach(function (p) {
                    var productId = p.getAttribute('data-product-id');
                    var heartBtn = p.querySelector('.product-heart-btn');
                    var isFavorited = !!favs[productId];

                    if (heartBtn) {
                        heartBtn.textContent = isFavorited ? '❤️' : '🤍';
                        heartBtn.title = isFavorited ? 'Odstrániť z obľúbených' : 'Pridať do obľúbených';
                    }

                    if (isFavorited) {
                        p.classList.add('is-favorited');
                    } else {
                        p.classList.remove('is-favorited');
                    }
                });
            }

            window.toggleProductFavorite = function (event, productId, productName, productImage, productPrice) {
                event.preventDefault();
                event.stopPropagation();

                var favs = loadFavorites();

                if (favs[productId]) {
                    delete favs[productId];
                } else {
                    favs[productId] = {
                        name: productName,
                        image: productImage,
                        price: parseFloat(productPrice)
                    };
                }

                saveFavorites(favs);
                updateProductFavoriteStatus();
            };

            // Initialize on page load
            document.addEventListener('DOMContentLoaded', function () {
                updateProductFavoriteStatus();
            });
        })();

        // Search functionality
        (function () {
            // Configuration
            var SEARCH_CONFIG = {
                showSpinner: true,
                spinnerDelay: 300,
                spinnerMinDuration: 600,
                overlayId: 'searchSpinnerOverlay'
            };

            // References
            var spinnerOverlay = document.getElementById(SEARCH_CONFIG.overlayId);
            var spinnerTimeout;
            var spinnerStartTime;

            function normalize(s) {
                return (s || '')
                    .toString()
                    .toLowerCase()
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function showSpinner() {
                if (!SEARCH_CONFIG.showSpinner || !spinnerOverlay) return;
                spinnerStartTime = Date.now();
                spinnerTimeout = setTimeout(function () {
                    spinnerOverlay.classList.add('show');
                }, SEARCH_CONFIG.spinnerDelay);
            }

            function hideSpinner() {
                if (!spinnerOverlay) return;
                clearTimeout(spinnerTimeout);
                var elapsed = Date.now() - spinnerStartTime;
                var remaining = Math.max(0, SEARCH_CONFIG.spinnerMinDuration - elapsed);
                setTimeout(function () {
                    spinnerOverlay.classList.remove('show');
                }, remaining);
            }

            function getQuery() {
                try {
                    var params = new URLSearchParams(window.location.search);
                    var q = params.get('q') || params.get('Q') || '';
                    return normalize(q);
                } catch (e) {
                    var m = /[?&]q=([^&]+)/i.exec(window.location.search || '');
                    return m ? normalize(decodeURIComponent(m[1].replace(/\+/g, ' '))) : '';
                }
            }

            function applySearch(q) {
                var sections = document.querySelectorAll('section.products');
                if (!sections || !sections.length) return;

                sections.forEach(function (s) {
                    s.classList.add('loading');
                });

                setTimeout(function () {
                    sections.forEach(function (s) {
                        s.classList.remove('product-hidden', 'product-match', 'loading');
                    });

                    if (!q) return;

                    var best = null;
                    var matchCount = 0;

                    for (var j = 0; j < sections.length; j++) {
                        var s = sections[j];
                        var name = normalize(s.getAttribute('data-product-name'));
                        var aliases = normalize(s.getAttribute('data-product-aliases'));
                        var hay = (name + ' ' + aliases);
                        var isMatch = hay.indexOf(q) >= 0;

                        if (!isMatch) {
                            var tokens = q.split(' ');
                            for (var t = 0; t < tokens.length; t++) {
                                if (tokens[t] && hay.indexOf(tokens[t]) >= 0) { 
                                    isMatch = true; 
                                    break; 
                                }
                            }
                        }

                        if (isMatch) {
                            matchCount++;
                            if (!best) best = s;
                        } else {
                            s.classList.add('product-hidden');
                        }
                    }

                    if (best) {
                        best.classList.remove('product-hidden');
                        best.classList.add('product-match');
                        try {
                            best.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        } catch (e) {
                            best.scrollIntoView(true);
                        }
                    }

                    hideSpinner();
                }, 100);
            }

            // Initialize
            var initialQuery = getQuery();
            if (initialQuery) {
                showSpinner();
                applySearch(initialQuery);
            }
        })();
    </script>
}


