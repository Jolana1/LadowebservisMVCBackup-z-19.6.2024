<!-- Products -->
@using LadowebservisMVC.Models
@model OrderModel

@{
    ViewBag.Title = "Produkty";
}

<style>
    /* ========== MAIN CONTAINER ========== */
    .products-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ========== HERO HEADER ========== */
    .products-hero {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        padding: 40px 20px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(93, 51, 251, 0.3);
    }

    .products-hero h2 {
        font-size: 28px;
        font-weight: 700;
        margin: 0;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    /* ========== PRODUCT CARDS ========== */
    .product-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-bottom: 30px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
    }

    .product-card.is-favorited {
        border: 2px solid #ff6b6b;
    }

    .product-heart-btn {
        position: absolute;
        top: 20px;
        left: 20px;
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 15;
    }

    .product-heart-btn:hover {
        transform: scale(1.2);
    }

    .product-heart-btn.favorited {
        animation: heartBeat 0.3s ease;
    }

    @@keyframes heartBeat {
        0% { transform: scale(1); }
        25% { transform: scale(1.3); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1.2); }
    }

    .product-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #ff4444;
        color: #fff;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        z-index: 10;
    }

    .product-badge.discount {
        background: #28a745;
    }

    .product-badge.new {
        background: #ff9800;
    }

    .product-header {
        text-align: center;
        margin-bottom: 20px;
    }

    .product-header h2 {
        color: #5d33fb;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .product-description {
        background: #e7f3ff;
        border-left: 4px solid #5d33fb;
        padding: 15px;
        margin: 20px 0;
        border-radius: 4px;
        font-size: 14px;
        color: #2c3e50;
    }

    /* ========== PRICING ========== */
    .product-pricing {
        text-align: center;
        margin: 25px 0;
    }

    .price-original {
        font-size: 18px;
        color: #999;
        text-decoration: line-through;
        margin-right: 10px;
    }

    .price-current {
        font-size: 32px;
        color: #28a745;
        font-weight: 700;
    }

    .price-save {
        display: inline-block;
        background: #ffeb3b;
        color: #2c3e50;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 10px;
    }

    /* ========== BUTTONS ========== */
    .product-actions {
        display: flex;
        gap: 15px;
        margin: 25px 0;
        flex-wrap: wrap;
    }

    .btn-stripe {
        flex: 1;
        background: linear-gradient(135deg, #635bff 0%, #5469d4 100%);
        color: #fff;
        padding: 15px 30px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-width: 200px;
    }

    .btn-stripe:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(99, 91, 255, 0.4);
        color: #fff;
    }

    .btn-add-cart {
        flex: 1;
        background: #5d33fb;
        color: #fff;
        padding: 15px 30px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-width: 200px;
    }

    .btn-add-cart:hover {
        background: #4a2fb5;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.4);
    }

    .btn-view-cart {
        flex: 1;
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff;
        padding: 15px 30px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-width: 200px;
    }

    .btn-view-cart:hover {
        background: linear-gradient(135deg, #138496 0%, #0e6674 100%);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(23, 162, 184, 0.4);
        color: #fff;
    }

    /* ========== PRODUCT IMAGE ========== */
    .product-image-container {
        text-align: center;
        margin: 25px 0;
        position: relative;
    }

    .product-image-container img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
    }

    .product-image-container:hover img {
        transform: scale(1.02);
    }

    /* ========== PRODUCT DETAILS ========== */
    .product-details {
        margin-top: 20px;
    }

    .product-details summary {
        background: #f5f5f5;
        padding: 15px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        color: #5d33fb;
        transition: background 0.3s ease;
    }

    .product-details summary:hover {
        background: #e8e8e8;
    }

    .product-details p {
        padding: 20px;
        line-height: 1.8;
        color: #555;
        background: #fafafa;
        border-radius: 0 0 8px 8px;
        margin-top: -8px;
    }

    /* ========== DISCOUNT NOTICE ========== */
    .discount-notice {
        background: linear-gradient(135deg, #ffeb3b 0%, #ffc107 100%);
        color: #2c3e50;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        margin: 20px 0;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(255,193,7,0.3);
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .products-hero h2 {
            font-size: 20px;
        }

        .product-card {
            padding: 20px;
        }

        .product-header h2 {
            font-size: 20px;
        }

        .product-actions {
            flex-direction: column;
        }

        .btn-stripe,
        .btn-add-cart {
            width: 100%;
            min-width: auto;
        }

        .price-current {
            font-size: 24px;
        }

        .product-badge {
            top: 10px;
            right: 10px;
            font-size: 10px;
            padding: 6px 12px;
        }
    }

    /* ========== SEARCH STATES ========== */
    .product-match {
        outline: 3px solid #5d33fb;
        box-shadow: 0 0 0 4px rgba(93,51,251,0.18);
    }

    .product-hidden {
        display: none !important;
    }

    /* ========== LOADING SPINNER ========== */
    .search-spinner-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.3);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .search-spinner-overlay.show {
        display: flex;
        opacity: 1;
    }

    .spinner-container {
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        text-align: center;
        max-width: 300px;
    }

    .spinner {
        border: 4px solid #f0f0f0;
        border-top: 4px solid #5d33fb;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        animation: spin 1s linear infinite;
        margin: 0 auto 16px;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .spinner-text {
        font-size: 14px;
        color: #555;
        font-weight: 500;
        margin: 0;
    }

    .spinner-text.sub {
        font-size: 12px;
        color: #999;
        margin-top: 8px;
        font-weight: normal;
    }
</style>

