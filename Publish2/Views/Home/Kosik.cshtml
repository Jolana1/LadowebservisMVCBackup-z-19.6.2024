            // Shipping / pickup selection
            (function initShippingUi() {
                var DPD_PICKUP_SUGGESTIONS_KEY = 'lws_dpd_pickup_points_v1';
                var methodSel = document.getElementById('lwsShippingMethodPage');
                var pickupWrap = document.getElementById('lwsZasielkovnaPickupWrapPage');
                var pickupSuggestions = document.getElementById('lwsDpdPickupSuggestionsPage');
                var courierWrap = document.getElementById('lwsCourierAddressWrapPage');
                var pickupCode = document.getElementById('lwsZasielkovnaPickupPointPage');
                var pickupName = document.getElementById('lwsZasielkovnaPickupPointNamePage');

                var addr1 = document.getElementById('lwsShipAddr1Page');
                var addr2 = document.getElementById('lwsShipAddr2Page');
                var city = document.getElementById('lwsShipCityPage');
                var zip = document.getElementById('lwsShipZipPage');
                var country = document.getElementById('lwsShipCountryPage');

                if (!methodSel) return;

                var pickupLabel = document.getElementById('pickupPointLabelPage');
                var pickupHelp = document.getElementById('pickupPointHelpPage');
                var shippingMethodPriceNote = document.getElementById('shippingMethodPriceNote');

                function loadShip() { return getNormalizedShipping(); }
                function saveShip(s) { saveShipping(s); }

                function loadDpdPickupSuggestions() {
                    try {
                        var items = JSON.parse(localStorage.getItem(DPD_PICKUP_SUGGESTIONS_KEY) || '[]');
                        return Array.isArray(items) ? items : [];
                    } catch (e) {
                        return [];
                    }
                }

                function saveDpdPickupSuggestions(items) {
                    try {
                        localStorage.setItem(DPD_PICKUP_SUGGESTIONS_KEY, JSON.stringify(items || []));
                    } catch (e) { }
                }

                function renderDpdPickupSuggestions(selectedCode) {
                    if (!pickupSuggestions) return;
                    var ship = loadShip();
                    var pickupMeta = getPickupMethodMeta((ship && ship.method) || '');

                    var items = loadDpdPickupSuggestions().filter(function (item) {
                        return item && item.code && item.name;
                    }).sort(function (a, b) {
                        var nameCompare = (a.name || '').localeCompare((b.name || ''), 'sk', { sensitivity: 'base' });
                        return nameCompare !== 0 ? nameCompare : (a.code || '').localeCompare((b.code || ''), 'sk', { sensitivity: 'base' });
                    });

                    pickupSuggestions.innerHTML = '<option value="">' + pickupMeta.placeholderOption + '</option>';
                    items.forEach(function (item) {
                        var option = document.createElement('option');
                        option.value = item.code;
                        option.textContent = item.code + ' - ' + item.name;
                        option.setAttribute('data-name', item.name);
                        if (selectedCode && selectedCode === item.code) {
                            option.selected = true;
                        }
                        pickupSuggestions.appendChild(option);
                    });

                    pickupSuggestions.style.display = items.length > 0 ? '' : 'none';
                }

                function rememberCurrentDpdPickup() {
                    var code = pickupCode ? (pickupCode.value || '').trim() : '';
                    var name = pickupName ? (pickupName.value || '').trim() : '';
                    if (!code || !name) return;

                    var items = loadDpdPickupSuggestions().filter(function (item) {
                        return item && item.code && item.name;
                    });
                    items = items.filter(function (item) { return item.code !== code; });
                    items.unshift({ code: code, name: name });
                    if (items.length > 8) items = items.slice(0, 8);
                    saveDpdPickupSuggestions(items);
                    renderDpdPickupSuggestions(code);
                }

                function getFirstDpdPickupSuggestion() {
                    var items = loadDpdPickupSuggestions().filter(function (item) {
                        return item && item.code && item.name;
                    }).sort(function (a, b) {
                        var nameCompare = (a.name || '').localeCompare((b.name || ''), 'sk', { sensitivity: 'base' });
                        return nameCompare !== 0 ? nameCompare : (a.code || '').localeCompare((b.code || ''), 'sk', { sensitivity: 'base' });
                    });

                    return items.length > 0 ? items[0] : null;
                }

                function getPickupMethodMeta(method) {
                    if (method === 'dpd-pickup') {
                        return {
                            label: 'Odberne miesto (DPD Pickup, potrebne zadat)',
