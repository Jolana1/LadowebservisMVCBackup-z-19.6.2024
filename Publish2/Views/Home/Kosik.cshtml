                    }
                    if (method === 'packeta-zbox' || method === 'packeta' || method === 'zasielkovna') {
                        return {
                            label: 'Box / odberne miesto (Packeta Z-BOX)',
                            help: 'Packeta Z-BOX funguje ako rucne zadanie boxu alebo vydajneho miesta. Platne udaje najdete na <a href="https://www.packeta.sk/pobocky" target="_blank" rel="noopener">stranke Packeta Slovensko</a>. Zadajte kod a nazov Z-BOXu alebo vydajneho miesta.',
