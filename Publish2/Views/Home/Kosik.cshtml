                    if (courierWrap) courierWrap.style.display = (ship && isCourierMethod(ship.method)) ? '' : 'none';
                    if (pickupCode) pickupCode.value = (ship && ship.pickupPoint) ? ship.pickupPoint : '';
                    if (pickupName) pickupName.value = (ship && ship.pickupPointName) ? ship.pickupPointName : '';
                    renderDpdPickupSuggestions(ship && ship.pickupPoint ? ship.pickupPoint : '');

                    if (addr1) addr1.value = (ship && ship.addressLine1) ? ship.addressLine1 : '';
                    if (addr2) addr2.value = (ship && ship.addressLine2) ? ship.addressLine2 : '';
                    if (city) city.value = (ship && ship.city) ? ship.city : '';
                    if (zip) zip.value = (ship && ship.zip) ? ship.zip : '';
                    if (country) country.value = (ship && ship.country) ? ship.country : '';
                    applyToHiddenFields(ship);
                    refreshShippingHelp(ship);
                }

                methodSel.addEventListener('change', function () {
                    var ship = loadShip();
                    ship.method = methodSel.value || '';
                    if (!isPickupMethod(ship.method)) {
                        ship.pickupPoint = '';
                        ship.pickupPointName = '';
                        ship.pickupPointJson = '';
                    }
                    if (!isCourierMethod(ship.method)) {
                        ship.addressLine1 = '';
                        ship.addressLine2 = '';
                        ship.city = '';
                        ship.zip = '';
                        ship.country = '';
                    }
                    saveShip(ship);
                    if (isPickupMethod(ship.method) && !ship.pickupPoint && !ship.pickupPointName) {
                        applyDpdPickupSuggestion(getFirstDpdPickupSuggestion());
                    }
                    syncUiFromStorage();
                    renderCartReview();
                    if (window.lwsRenderCartHeader) window.lwsRenderCartHeader();
                });

                function saveCourier() {
                    var ship = loadShip();
                    ship.method = ship.method || methodSel.value || '';
                    ship.addressLine1 = addr1 ? (addr1.value || '') : '';
                    ship.addressLine2 = addr2 ? (addr2.value || '') : '';
                    ship.city = city ? (city.value || '') : '';
                    ship.zip = zip ? (zip.value || '') : '';
                    ship.country = country ? (country.value || '') : '';
                    saveShip(ship);
                    applyToHiddenFields(ship);
                    renderCartReview();
                }

                if (addr1) addr1.addEventListener('input', saveCourier);
                if (addr2) addr2.addEventListener('input', saveCourier);
                if (city) city.addEventListener('input', saveCourier);
                if (zip) zip.addEventListener('input', saveCourier);
                if (country) country.addEventListener('input', saveCourier);

                if (pickupCode) {
                    pickupCode.addEventListener('input', function () {
                        var ship = loadShip();
                        ship.method = ship.method || methodSel.value || 'dpd-pickup';
                        ship.pickupPoint = pickupCode.value || '';
                        saveShip(ship);
                        applyToHiddenFields(ship);
                        renderCartReview();
                    });
                    pickupCode.addEventListener('blur', rememberCurrentDpdPickup);
                }
                if (pickupName) {
                    pickupName.addEventListener('input', function () {
                        var ship = loadShip();
                        ship.method = ship.method || methodSel.value || 'dpd-pickup';
                        ship.pickupPointName = pickupName.value || '';
                        saveShip(ship);
                        applyToHiddenFields(ship);
                        renderCartReview();
                    });
                    pickupName.addEventListener('blur', rememberCurrentDpdPickup);
                }
                if (pickupSuggestions) {
                    pickupSuggestions.addEventListener('change', function () {
                        var selected = pickupSuggestions.options[pickupSuggestions.selectedIndex];
                        if (!selected || !selected.value) return;

                        var code = selected.value || '';
                        var name = selected.getAttribute('data-name') || '';
                        if (pickupCode) pickupCode.value = code;
                        if (pickupName) pickupName.value = name;

                        var ship = loadShip();
                        ship.method = ship.method || methodSel.value || 'dpd-pickup';
                        ship.pickupPoint = code;
                        ship.pickupPointName = name;
                        saveShip(ship);
                        applyToHiddenFields(ship);
                        renderCartReview();
                        rememberCurrentDpdPickup();
                    });
                }

                // initial
                syncUiFromStorage();
                if (typeof window.lwsSetShippingMethod === 'function' && methodSel && methodSel.value) {
                    window.lwsSetShippingMethod(methodSel.value);
                }
            })();

            // Submit UI feedback
            (function initSubmitFeedback() {
                function onSubmit(formId, statusId, submitBtnId, busyText) {
                    var form = document.getElementById(formId);
                    if (!form) return;
                    form.addEventListener('submit', function () {
                        try {
                            hydrateOrderFormFromStorage();
                            var normalizedShip = getNormalizedShipping();
                            applyToHiddenFields(normalizedShip);
                            renderCartReview();
                            var status = document.getElementById(statusId);
                            if (status) status.style.display = '';
                            var btn = document.getElementById(submitBtnId);
                            if (btn) {
                                btn.disabled = true;
                                btn.innerHTML = busyText;
                            }
                        } catch (e) { }
                    });
                }

                onSubmit('placeOrderForm', 'placeOrderStatus', 'placeOrderSubmitBtn', '<i class="fa fa-spinner fa-spin"></i> Odosielam...');
            })();

            // Search functionality - match products by name and ID
            var searchInput = document.getElementById('productSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var searchTerm = this.value.toLowerCase().trim();
                    var productCards = document.querySelectorAll('#productsContainer [data-product-id]');
                    var visibleCount = 0;

                    productCards.forEach(function (card) {
                        var productName = card.getAttribute('data-product-name') || '';
                        var productId = card.getAttribute('data-product-id') || '';
                        var searchableText = (productName + ' ' + productId).toLowerCase();

                        // Show/hide based on search match
                        var matches = !searchTerm || searchableText.indexOf(searchTerm) >= 0;
                        card.style.display = matches ? '' : 'none';

                        if (matches) {
                            visibleCount++;
                        }
                    });

                    // Update product count display
                    var allCount = productCards.length;
                    var productCountEl = document.getElementById('productCount');
                    if (productCountEl) {
                        if (searchTerm) {
                            productCountEl.textContent = '(' + visibleCount + ' z ' + allCount + ' produktov)';
                        } else {
                            productCountEl.textContent = '(' + allCount + ' produktov)';
                        }
                    }
                });
            }
        })();
    </script>
}























































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































