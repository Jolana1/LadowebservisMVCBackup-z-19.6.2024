@using LadowebservisMVC.Util

@{
    // Track IDs to avoid rendering duplicate entries
    var seenIds = new System.Collections.Generic.HashSet<string>(System.StringComparer.OrdinalIgnoreCase);
}

<style>
    /* ========== MAIN CONTAINER ========== */
    .kosik-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ========== HERO HEADER ========== */
    .kosik-hero {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        padding: 40px 20px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(93, 51, 251, 0.3);
    }

    .kosik-hero h2 {
        font-size: 24px;
        font-weight: 700;
        margin: 0 0 20px 0;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        line-height: 1.6;
        color: #fff;
    }

    .kosik-hero h2 small {
        color: #fff;
    }

    /* ========== DISCOUNT NOTICE ========== */
    .discount-notice {
        background: linear-gradient(135deg, #ffeb3b 0%, #ffc107 100%);
        color: #2c3e50;
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
        text-align: center;
    }

    .discount-notice code {
        background: #fff;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 700;
        color: #5d33fb;
        font-size: 16px;
    }

    /* ========== CARD SECTIONS ========== */
    .kosik-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        padding: 30px;
        margin-bottom: 30px;
    }

    .kosik-card h3 {
        color: #5d33fb;
        font-weight: 700;
        margin-bottom: 25px;
        font-size: 22px;
    }

    /* ========== PRODUCT CARDS ========== */
    .product-card {
        position: relative;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #fff;
    }

    .product-card.in-cart {
        border-color: #28a745;
        background: linear-gradient(135deg, #f0fff4 0%, #e8f5e9 100%);
        box-shadow: 0 4px 15px rgba(40, 167, 69, 0.15);
    }

    .product-card:hover {
        border-color: #5d33fb;
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.15);
        transform: translateY(-3px);
    }

    .product-card.in-cart:hover {
        border-color: #28a745;
        box-shadow: 0 8px 20px rgba(40, 167, 69, 0.25);
    }

    .product-qty-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        border: 2px solid #fff;
        z-index: 5;
    }

    .product-in-cart-label {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        z-index: 4;
    }

    .product-card img {
        max-width: 100%;
        max-height: 120px;
        width: auto;
        height: auto;
        object-fit: contain;
        margin: 0 auto;
    }

    .product-card h4 {
        color: #2c3e50;
        font-size: 16px;
        font-weight: 600;
        margin: 15px 0 10px;
    }

    .product-card p {
        color: #28a745;
        font-size: 20px;
        font-weight: 700;
        margin: 10px 0;
    }

    /* ========== BUTTONS ========== */
    .btn-detail {
        background: #17a2b8;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-detail:hover {
        background: #138496;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .btn-add-cart {
        background: #5d33fb;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover {
        background: #4a2fb5;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .product-heart {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 10;
    }

    .product-heart .fa-heart {
        font-size: 20px;
        color: #e25555;
        transition: all 0.3s ease;
    }

    .product-heart:hover .fa-heart {
        transform: scale(1.2);
    }

    /* ========== CART REVIEW ========== */
    .cart-item {
        border: 2px solid #f0f0f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

    .cart-item:hover {
        border-color: #5d33fb;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.1);
    }

    .cart-item-discount {
        background: #e7f3ff;
        border-color: #28a745;
    }

    .cart-recommendations {
        margin: 25px 0;
        padding: 20px;
        border-radius: 12px;
        background: linear-gradient(135deg, #f8faff 0%, #eef3ff 100%);
        border: 1px solid rgba(93, 51, 251, 0.12);
    }

    .cart-recommendations h4 {
        color: #5d33fb;
        font-weight: 700;
        margin: 0 0 8px 0;
    }

    .cart-recommendations p {
        margin: 0 0 18px 0;
        color: #666;
        font-size: 14px;
    }

    .recommendation-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 16px;
    }

    .recommendation-card {
        background: #fff;
        border: 1px solid rgba(93, 51, 251, 0.10);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        box-shadow: 0 8px 18px rgba(36, 50, 74, 0.08);
        height: 100%;
    }

    .recommendation-card img {
        max-width: 100%;
        height: 110px;
        object-fit: contain;
        margin-bottom: 10px;
    }

    .recommendation-title {
        color: #2c3e50;
        font-size: 15px;
        font-weight: 700;
        min-height: 42px;
        margin-bottom: 8px;
    }

    .recommendation-price {
        color: #28a745;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .recommendation-points {
        color: #5d33fb;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .cart-item img {
        max-width: 120px;
        max-height: 120px;
        object-fit: contain;
        border-radius: 8px;
    }

    .discount-badge {
        display: inline-block;
        background: #28a745;
        color: #fff;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 10px;
    }

    .price-original {
        text-decoration: line-through;
        color: #999;
        margin-right: 8px;
    }

    .price-discounted {
        color: #28a745;
        font-weight: 700;
    }

    /* ========== TOTALS ========== */
    .cart-totals {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
    }

    .cart-totals .row {
        margin-bottom: 10px;
        font-size: 16px;
    }

    .cart-totals .row:last-child {
        border-top: 2px solid #5d33fb;
        padding-top: 15px;
        margin-top: 15px;
        font-size: 20px;
        font-weight: 700;
    }

    .loyalty-points-note {
        margin-top: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #5d33fb;
        text-align: right;
    }

    .hero-nav-buttons {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
    }

    .hero-nav-buttons .btn {
        white-space: normal;
        max-width: 100%;
    }

    .stripe-checkout-wrap {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow: hidden;
    }

    .stripe-checkout-wrap stripe-buy-button {
        display: block;
        max-width: 100%;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .kosik-container {
            padding: 12px;
        }

        .kosik-hero h2 {
            font-size: 18px;
        }

        .hero-nav-buttons {
            flex-direction: column;
            align-items: stretch;
        }

        .hero-nav-buttons .btn {
            width: 100%;
            margin-right: 0 !important;
        }

        .kosik-card {
            padding: 20px;
            overflow: hidden;
        }

        .cart-item {
            padding: 15px;
        }

        .cart-item img {
            max-width: 80px;
            max-height: 80px;
        }

        .cart-recommendations {
            padding: 16px;
        }

        .recommendation-grid {
            grid-template-columns: 1fr;
        }

        .recommendation-title {
            min-height: 0;
        }

        .cart-totals .row {
            display: block;
            text-align: left;
        }

        .cart-totals .row .col,
        .cart-totals .row .col-auto {
            width: 100%;
            max-width: 100%;
            text-align: left !important;
        }

        .loyalty-points-note {
            text-align: left;
        }

        .footer-action-buttons {
            flex-direction: column;
        }

        .footer-btn {
            width: 100%;
            justify-content: center;
            padding: 12px 18px;
        }

        #stripeCheckoutForm {
            min-width: 0;
        }

        .stripe-checkout-wrap {
            transform: scale(0.94);
            transform-origin: center top;
        }
    }

    @@media (max-width: 420px) {
        .stripe-checkout-wrap {
            transform: scale(0.86);
        }
    }

    /* ========== ALERT STYLES ========== */
    .alert-info {
        background: #e7f3ff;
        border: 2px solid #5d33fb;
        border-radius: 8px;
        padding: 20px;
    }

    .alert-info h4 {
        color: #5d33fb;
        margin-top: 0;
    }

    /* Fly-to-cart image animation */
    .lws-fly-img {
        position: absolute !important;
        pointer-events: none;
        z-index: 9999;
        border-radius: 6px;
        transition: transform 0.8s ease-in-out, opacity 0.8s ease-in-out;
        opacity: 1;
        will-change: transform, opacity;
    }

    /* ========== FOOTER BUTTONS ========== */
    .footer-action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .footer-btn {
        padding: 14px 32px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .footer-btn-primary {
        background: linear-gradient(135deg, #5d33fb 0%, #4a2fb5 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(93, 51, 251, 0.3);
    }

    .footer-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(93, 51, 251, 0.4);
        color: #fff;
    }

    .footer-btn-secondary {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
    }

    .footer-btn-secondary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(23, 162, 184, 0.4);
        color: #fff;
    }
</style>

<div class="kosik-container">

    <!-- Hero Header -->
    <div class="kosik-hero">
        <h2>
            🛒 Košík - Skontrolujte si produkty a dokončite objednávku<br>
            <small style="font-size: 16px; opacity: 0.9;">Môžete pridávať, upravovať množstvo alebo odstraňovať položky</small>
        </h2>

        <div class="discount-notice">
            🎉 V tomto košíku je celkova suma už automaticky odrátaná o 10% zľavu. Ďakujeme za Vašu objednávku! Pri platbe cez Stripe použite kód <code>LETOJETU26</code> a získajte 10% zľavu na vybrané produkty
        </div>



        <!-- Navigation Buttons -->
        <div class="text-center mt-4 hero-nav-buttons">
            <a href="@Url.Action("Login","Home")" class="btn btn-light me-2 mb-2">
                <i class="fa fa-user"></i> Prihlásenie
            </a>
            <a href='@Url.Action("Favorites","Home")' class="btn btn-light me-2 mb-2">
                <i class="fa fa-heart"></i> Obľúbené
            </a>
            <a href='@Url.Action("Zdravie","Home", new { area = "Ladowebservis" })' class="btn btn-light me-2 mb-2">
                <i class="fa fa-home"></i> Späť na úvod
            </a>
            <button type="button" class="btn btn-light mb-2" onclick="openSideCart()">
                <i class="fa fa-shopping-cart"></i> Skontrolovať košík
            </button>
        </div>
    </div>
    <!-- Cart Review Section -->
    <div class="kosik-card">
        <h3>🛍️ Položky v košíku</h3>

        <div id="cartReviewList" class="mb-4">
            <!-- items rendered by JS -->
        </div>

        <div id="cartRecommendations" class="cart-recommendations" style="display:none;">
            <h4>💡 Odporúčame aj podobné produkty</h4>
            <p>Na základe produktov vo Vašom košíku by sa Vám mohli hodiť aj tieto doplnky.</p>
            <div id="cartRecommendationsList" class="recommendation-grid"></div>
        </div>

        <!-- Cart Totals -->
        <div class="cart-totals" id="cartTotalsSection" style="display: none;">
            <div class="row">
                <div class="col text-end">Medzisúčet:</div>
                <div class="col-auto"><strong id="cartSubtotal">€0.00</strong></div>
            </div>
            <div class="row" id="discountRow" style="display: none;">
                <div class="col text-end" style="color:#28a745;">Zľava 10% (na vybrané produkty):</div>
                <div class="col-auto" style="color:#28a745;"><strong id="cartDiscount">-€0.00</strong></div>
            </div>
            <div class="row" id="shippingRow" style="display: none;">
                <div class="col text-end">Doprava <span id="cartShippingMethodLabel" class="text-muted" style="font-size:13px;"></span>:</div>
                <div class="col-auto"><strong id="cartShippingFee">€0.00</strong></div>
            </div>
            <div class="row">
                <div class="col text-end"><strong>Celková suma s DPH:</strong></div>
                <div class="col-auto text-end">
                    <strong id="cartTotal" style="color:#5d33fb; font-size: 24px;">€0.00</strong>
                    <div id="cartLoyaltyPoints" class="loyalty-points-note">Po zaplatení získate 0 bodov do vernostného programu</div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <button id="clear-cart-btn" class="btn btn-danger btn-lg">
                <i class="fa fa-trash"></i> Vyprázdniť košík
            </button>

        </div>

        <!-- Shipping + Order (bank transfer) -->
        <div class="alert alert-info mt-4" style="border-color:#17a2b8;">
            <h4><i class="fa fa-truck"></i>Bankový prevod a odoslanie objednávky</h4>
            <p class="mb-3">Vyberte spôsob dopravy a potom si zvoľte platbu cez Stripe alebo bankový prevod. Doprava, suma aj údaje sa vždy preberajú z aktuálneho košíka.</p>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="lwsShippingMethodPage">Doprava</label>
                        <select id="lwsShippingMethodPage" class="form-control">
                            <option value="courier">Kuriér na adresu</option>
                            <option value="gls-courier">GLS kuriér na adresu</option>
                            <option value="gls-parcelshop">GLS ParcelShop</option>
                            <option value="gls-box">GLS Box</option>
                            <option value="alzabox">AlzaBox</option>
                            <option value="dpd-courier">DPD kuriér na adresu</option>
                            <option value="dpd-pickup">DPD odberné miesto</option>
                            <option value="packeta-zbox">Packeta Z-BOX</option>
                        </select>
                        <small id="shippingMethodPriceNote" class="text-muted" style="display:block; margin-top:6px;">Cena dopravy sa prepočíta podľa zvolenej služby a hodnoty košíka.</small>
                    </div>
                    <div id="lwsZasielkovnaPickupWrapPage" class="form-group" style="display:none;">
                        <label for="lwsZasielkovnaPickupPointPage" id="pickupPointLabelPage">Odberne miesto / box (volitelne)</label>
                        <select id="lwsDpdPickupSuggestionsPage" class="form-control" style="margin-bottom: 8px; display:none;">
                            <option value="">Vyberte ulozene odberne miesto...</option>
                        </select>
                        <input id="lwsZasielkovnaPickupPointPage" type="text" class="form-control" placeholder="Kod odberneho miesta (volitelne)" style="margin-bottom: 8px;" />
                        <input id="lwsZasielkovnaPickupPointNamePage" type="text" class="form-control" placeholder="Nazov / adresa odberneho miesta (volitelne)" />
                        <small id="pickupPointHelpPage" class="text-muted">Zadajte kod a nazov odberneho miesta alebo boxu rucne. Platne udaje najdete na webe zvoleneho dopravcu.</small>
                    </div>

                    <div id="lwsCourierAddressWrapPage" class="form-group" style="display:none;">
                        <label>Doručovacia adresa (kuriér)</label>
                        <input id="lwsShipAddr1Page" type="text" class="form-control" placeholder="Ulica a číslo" style="margin-bottom: 8px;" />
                        <input id="lwsShipAddr2Page" type="text" class="form-control" placeholder="Byt / poschodie / poznámka (voliteľné)" style="margin-bottom: 8px;" />
                        <div class="row">
                            <div class="col-md-7" style="margin-bottom: 8px;">
                                <input id="lwsShipCityPage" type="text" class="form-control" placeholder="Mesto" />
                            </div>
                            <div class="col-md-5" style="margin-bottom: 8px;">
                                <input id="lwsShipZipPage" type="text" class="form-control" placeholder="PSČ" />
                            </div>
                        </div>
                        <input id="lwsShipCountryPage" type="text" class="form-control" placeholder="Krajina (napr. Slovensko)" />
                    </div>
                </div>

                <div class="col-md-6">
                    @using (Html.BeginForm("PlaceOrder", "Home", FormMethod.Post, new { id = "placeOrderForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CartJson" id="cartJsonInputPlaceOrder" value="" />
                        <input type="hidden" name="PaymentMethod" value="bank" />
                        <input type="hidden" name="ShippingMethod" id="shippingMethodInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPoint" id="zasielkovnaPickupInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointName" id="zasielkovnaPickupNameInput" value="" />
                        <input type="hidden" name="PickupPointDetailsJson" id="pickupPointDetailsJsonInput" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointJson" id="zasielkovnaPickupJsonInput" value="" />

                        <input type="hidden" name="ShippingAddressLine1" id="shippingAddressLine1Input" value="" />
                        <input type="hidden" name="ShippingAddressLine2" id="shippingAddressLine2Input" value="" />
                        <input type="hidden" name="ShippingCity" id="shippingCityInput" value="" />
                        <input type="hidden" name="ShippingZip" id="shippingZipInput" value="" />
                        <input type="hidden" name="ShippingCountry" id="shippingCountryInput" value="" />

                        <div class="form-group">
                            <label for="name_placeorder">Meno</label>
                            <input id="name_placeorder" name="Name" type="text" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label for="email_placeorder">Email</label>
                            <input id="email_placeorder" name="Email" type="email" class="form-control" required />
                        </div>
                        <button id="placeOrderSubmitBtn" type="submit" class="btn btn-primary btn-lg" style="width:100%;">
                            <i class="fa fa-envelope"></i> Dokončiť objednávku pre (bankový prevod)
                        </button>
                        <div id="placeOrderHelp" class="text-muted" style="margin-top:10px; font-size: 13px; line-height: 1.45;">
                            Bankovy prevod pouzije rovnaku dopravu a cenu ako kosik. Po odoslani objednavky posleme e-mail so suhrnom, cislom objednavky a udajmi k platbe.
                            Skontrolujte aj priecinok SPAM.
                        </div>
                        <div id="placeOrderStatus" class="alert alert-info" style="display:none; margin-top:12px;">
                            Objednávku odosielame… Prosím počkajte.
                        </div>
                    }

                    @using (Html.BeginForm("StartStripeCheckout", "Home", FormMethod.Post, new { id = "stripeCheckoutForm", style = "margin-top:10px;" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CartJson" id="cartJsonInputStripeCheckout" value="" />
                        <input type="hidden" name="Name" id="name_stripe_checkout" value="" />
                        <input type="hidden" name="Email" id="email_stripe_checkout" value="" />
                        <input type="hidden" name="PaymentMethod" value="stripe" />
                        <input type="hidden" name="ShippingMethod" id="shippingMethodInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPoint" id="zasielkovnaPickupInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointName" id="zasielkovnaPickupNameInputStripe" value="" />
                        <input type="hidden" name="PickupPointDetailsJson" id="pickupPointDetailsJsonInputStripe" value="" />
                        <input type="hidden" name="ZasielkovnaPickupPointJson" id="zasielkovnaPickupJsonInputStripe" value="" />

                        <input type="hidden" name="ShippingAddressLine1" id="shippingAddressLine1InputStripe" value="" />
                        <input type="hidden" name="ShippingAddressLine2" id="shippingAddressLine2InputStripe" value="" />
                        <input type="hidden" name="ShippingCity" id="shippingCityInputStripe" value="" />
                        <input type="hidden" name="ShippingZip" id="shippingZipInputStripe" value="" />
